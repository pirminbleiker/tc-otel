{
  "logging": {
    "log_level": "debug",
    "format": "text",
    "output_path": null
  },
  "receiver": {
    "host": "127.0.0.1",
    "http_port": 4318,
    "grpc_port": 4317,
    "max_body_size": 4194304,
    "request_timeout_secs": 30,
