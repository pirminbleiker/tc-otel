<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="PRG_TestMetricApi" Id="{aee44ed6-ce24-03ca-2c62-32698b23b61f}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM PRG_TestMetricApi
VAR
	(* FB_Metrics smoke instances — exercise each body schema. *)
	fbSineLreal     : FB_Metrics;
	fbToggleBool    : FB_Metrics;
	fbStateString   : FB_Metrics;
	(* Phase 7: same sine fed into an aggregating instance — the receiver
	   sees min/max/mean per sample tick instead of an under-sampled raw
	   value, so the envelope stays sharp even at 50 ms / 5 s cadence. *)
	fbSineAgg       : FB_Metrics;

	(* Driver state. *)
	rPhase          : LREAL;
	rSineValue      : LREAL;
	bToggle         : BOOL;
	sState          : STRING(31) := 'idle';
	nStateSwitch    : UDINT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF TwinCAT_SystemInfoVarList._TaskInfo[GETCURTASKINDEXEX()].FirstCycle THEN
	// FB_Metrics demo: LREAL sine → eNumeric body schema, push every 5 s.
	fbSineLreal.Init('demo.sine', 'unit');
	fbSineLreal.SetSampleIntervalMs(50);
	fbSineLreal.SetPushIntervalMs(5000);

	// BOOL toggle → eBool, push every 2 s.
	fbToggleBool.Init('demo.toggle', '');
	fbToggleBool.SetPushIntervalMs(2000);

	// STRING state → eString (fixed 32 B per sample), push every 10 s.
	fbStateString.Init('demo.state', '', 32);
	fbStateString.SetPushIntervalMs(10000);

	// Aggregated sine: same source, same 50 ms / 5 s cadence — but
	// SetAggregation(eMin OR eMax OR eMean) folds every Observe into
	// Welford online so each sample tick captures the real envelope of
	// the underlying signal instead of a stochastic point on it.
	fbSineAgg.Init('demo.sineAgg', 'unit');
	fbSineAgg.SetSampleIntervalMs(50);
	fbSineAgg.SetPushIntervalMs(5000);
	fbSineAgg.SetAggregation(E_MetricStat.eMean OR E_MetricStat.eMax OR E_MetricStat.eMin);
END_IF

// Drive the sine: phase advances 0.005 rad per 1 ms task cycle ≈ 0.8 Hz.
// Combined with SetSampleIntervalMs(50) → ~25 samples per period — clean
// curve in Grafana (well above Nyquist, no visible aliasing).
rPhase     := rPhase + 0.005;
rSineValue := SIN(rPhase);
fbSineLreal.Observe(rSineValue);
fbSineAgg.Observe(rSineValue);

// BOOL toggles every 250 cycles for an obvious square wave on the wire.
IF (TwinCAT_SystemInfoVarList._TaskInfo[GETCURTASKINDEXEX()].CycleCount MOD 250) = 0 THEN
	bToggle := NOT bToggle;
END_IF
fbToggleBool.Observe(bToggle);

// State machine flips through 3 strings every ~3 s (3000 cycles at 1 ms).
nStateSwitch := nStateSwitch + 1;
IF nStateSwitch >= 3000 THEN
	nStateSwitch := 0;
	IF sState = 'idle' THEN
		sState := 'running';
	ELSIF sState = 'running' THEN
		sState := 'paused';
	ELSE
		sState := 'idle';
	END_IF
END_IF
fbStateString.Observe(sState);

]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>