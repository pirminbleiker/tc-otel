<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_TcOtelTaskTracer" Id="{294f80cd-71bb-4a49-ab79-358e75196d66}" SpecialFunc="None">
    <Declaration><![CDATA[(*
:Description: Per-task low-level OpenTelemetry trace wire transport.

INTERNAL — do not call directly from user code. One instance per task lives
in PRG_TaskLog.aTaskTracer. Wire-emit methods are called only by
FB_TcOtelTracer (the public instance-tracer API). Each method emits exactly
one wire event into the existing ADS write buffer (same path the logger uses).
Wire events are demuxed by tc-otel into a SpanEventDispatcher.

Wire format documented in docs/traces-design.md Section "Wire Format".

Users should use FB_TcOtelTracer and FB_Span instead.
*)
{attribute 'no_explicit_call' := 'no direct call necessary'}
{attribute 'conditionalshow'}
FUNCTION_BLOCK FB_TcOtelTaskTracer
VAR
    (* Phase 6 Stage 3: innermost-open span chain. Spans register/unregister
       as they begin/end. NULL when no spans are open. *)
    _pInnermost      : POINTER TO FB_Span;

    (* Wire format constants *)
    nEventTypeBegin  : BYTE := 5;
    nEventTypeAttr   : BYTE := 6;
    nEventTypeEvent  : BYTE := 7;
    nEventTypeEnd    : BYTE := 8;

    (* xorshift64 PRNG state used to mint W3C trace_id / span_id locally.
       Seeded on first Begin() call from the DC clock XOR the task index so
       separate tasks do not produce the same stream. OTel spec only
       requires randomly generated IDs — xorshift is sufficient and costs
       ~6 ops per 64-bit draw. *)
    _nXorState       : ULINT := 16#DEADBEEFCAFEF00D;
    _bRngSeeded      : BOOL  := FALSE;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="_GetTaskDcTime" Id="{9b32520a-c9fc-420a-8034-c0663bb4b6b9}">
      <Declaration><![CDATA[METHOD PRIVATE _GetTaskDcTime : LINT
VAR
    nTaskIdx : DINT;
    pTaskInfo : POINTER TO PlcTaskSystemInfo;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
nTaskIdx := Tc2_Utilities.GETCURTASKINDEXEX();
IF nTaskIdx > 0 AND nTaskIdx <= SIZEOF(TwinCAT_SystemInfoVarList._TaskInfo) / SIZEOF(PlcTaskSystemInfo) THEN
    pTaskInfo := ADR(TwinCAT_SystemInfoVarList._TaskInfo[nTaskIdx]);
    _GetTaskDcTime := pTaskInfo^.DcTaskTime;
ELSE
    _GetTaskDcTime := 0;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SeedRng" Id="{1a8f2c4d-3b5e-4a6f-8d7c-9e0a1b2c3d4f}">
      <Declaration><![CDATA[METHOD PRIVATE _SeedRng
VAR
    nDcTime : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF _bRngSeeded THEN
    RETURN;
END_IF;

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;

(* XOR with task index so separate tasks can't produce the same stream
   if two of them seed within the same DC-time tick. Add the fallback
   constant so a zero DC clock still gives a non-zero seed (xorshift64
   requires non-zero state). *)
_nXorState := TO_ULINT(nDcTime) XOR (TO_ULINT(Tc2_Utilities.GETCURTASKINDEXEX()) * 16#9E3779B97F4A7C15);
IF _nXorState = 0 THEN
    _nXorState := 16#DEADBEEFCAFEF00D;
END_IF;

_bRngSeeded := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_NextRandom" Id="{2b9e3d5f-4c6a-4b7d-8e9f-0a1b2c3d4e5f}">
      <Declaration><![CDATA[(* xorshift64 (Marsaglia 2003): 6 ops, period 2^64 - 1, zero lookup tables. *)
METHOD PRIVATE _NextRandom : ULINT
VAR
    x : ULINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
x := _nXorState;
x := x XOR SHL(x, 13);
x := x XOR SHR(x, 7);
x := x XOR SHL(x, 17);
_nXorState := x;
_NextRandom := x;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_MintTraceId" Id="{3c0a4e6b-5d7c-4e8f-9a0b-1c2d3e4f5a6b}">
      <Declaration><![CDATA[(* Fills the 16-byte trace_id of the FB_Span with two xorshift64 draws. *)
METHOD PRIVATE _MintTraceId
VAR_INPUT
    pSpan : POINTER TO FB_Span;
END_VAR
VAR
    hi  : ULINT;
    lo  : ULINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

hi := _NextRandom();
lo := _NextRandom();
Tc2_System.MEMCPY(ADR(pSpan^._abTraceId[0]), ADR(hi), 8);
Tc2_System.MEMCPY(ADR(pSpan^._abTraceId[8]), ADR(lo), 8);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_MintSpanId" Id="{4d1b5f7c-6e8d-4f9a-0b1c-2d3e4f5a6b7c}">
      <Declaration><![CDATA[(* Fills the 8-byte span_id of the FB_Span with one xorshift64 draw. *)
METHOD PRIVATE _MintSpanId
VAR_INPUT
    pSpan : POINTER TO FB_Span;
END_VAR
VAR
    v : ULINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

v := _NextRandom();
Tc2_System.MEMCPY(ADR(pSpan^._abSpanId[0]), ADR(v), 8);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_HexCharToNibble" Id="{6a5b4c3d-2e1f-4a5b-8c7d-9e0f1a2b3c4d}">
      <Declaration><![CDATA[(* Convert one hex ASCII byte ('0'-'9', 'a'-'f', 'A'-'F') into a 4-bit nibble.
   Returns FALSE for any other byte. Used by _ParseTraceParent. *)
METHOD PRIVATE _HexCharToNibble : BOOL
VAR_INPUT
    ch : BYTE;
END_VAR
VAR_IN_OUT
    nNibble : BYTE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF ch >= 16#30 AND ch <= 16#39 THEN
    nNibble := ch - 16#30;                  (* '0'..'9' -> 0..9 *)
    _HexCharToNibble := TRUE;
ELSIF ch >= 16#61 AND ch <= 16#66 THEN
    nNibble := ch - 16#57;                  (* 'a'..'f' -> 10..15 *)
    _HexCharToNibble := TRUE;
ELSIF ch >= 16#41 AND ch <= 16#46 THEN
    nNibble := ch - 16#37;                  (* 'A'..'F' -> 10..15 *)
    _HexCharToNibble := TRUE;
ELSE
    _HexCharToNibble := FALSE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_ParseTraceParent" Id="{7b6c5d4e-3f2a-4b6c-9d8e-0f1a2b3c4d5e}">
      <Declaration><![CDATA[(* Parse a W3C traceparent string into raw trace_id (16B) and span_id (8B) bytes.
   Expected format: "00-<32 hex>-<16 hex>-<2 hex>", total 55 chars.
   Returns TRUE on success (abTraceId / abSpanId populated), FALSE on any
   validation failure. On failure, output arrays may be partially written —
   callers must treat FALSE as "ignore outputs". *)
METHOD PRIVATE _ParseTraceParent : BOOL
VAR_INPUT
    sTp : STRING(60);
END_VAR
VAR_IN_OUT
    abTraceId : ARRAY[0..15] OF BYTE;
    abSpanId  : ARRAY[0..7]  OF BYTE;
END_VAR
VAR
    pBytes : POINTER TO BYTE;
    i      : INT;
    nHi    : BYTE;
    nLo    : BYTE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
_ParseTraceParent := FALSE;

(* W3C traceparent is exactly 55 ASCII characters. *)
IF Tc2_Utilities.LEN2(ADR(sTp)) < 55 THEN
    RETURN;
END_IF;

pBytes := ADR(sTp);

(* Version "00" — other versions unrecognised, reject *)
IF pBytes[0] <> 16#30 OR pBytes[1] <> 16#30 THEN
    RETURN;
END_IF;

(* Delimiters at positions 2, 35, 52 *)
IF pBytes[2] <> 16#2D OR pBytes[35] <> 16#2D OR pBytes[52] <> 16#2D THEN
    RETURN;
END_IF;

(* Flags must be "00" (not sampled) or "01" (sampled). Other values are
   reserved; reject to stay conservative. *)
IF pBytes[53] <> 16#30 THEN
    RETURN;
END_IF;
IF pBytes[54] <> 16#30 AND pBytes[54] <> 16#31 THEN
    RETURN;
END_IF;

(* Decode trace_id: 32 hex chars at offset 3 -> 16 bytes *)
FOR i := 0 TO 15 DO
    IF NOT _HexCharToNibble(pBytes[3 + i * 2], nHi) THEN
        RETURN;
    END_IF;
    IF NOT _HexCharToNibble(pBytes[3 + i * 2 + 1], nLo) THEN
        RETURN;
    END_IF;
    abTraceId[i] := SHL(nHi, 4) OR nLo;
END_FOR;

(* Decode span_id: 16 hex chars at offset 36 -> 8 bytes *)
FOR i := 0 TO 7 DO
    IF NOT _HexCharToNibble(pBytes[36 + i * 2], nHi) THEN
        RETURN;
    END_IF;
    IF NOT _HexCharToNibble(pBytes[36 + i * 2 + 1], nLo) THEN
        RETURN;
    END_IF;
    abSpanId[i] := SHL(nHi, 4) OR nLo;
END_FOR;

_ParseTraceParent := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_WriteFrameHeader" Id="{5c95a435-e5f4-4be0-a30e-3e2cecf13cfe}">
      <Declaration><![CDATA[METHOD PRIVATE _WriteFrameHeader
VAR_INPUT
    pWriteBuffer : POINTER TO FB_LogBuffer;
    nEventType   : BYTE;
    hSpan        : USINT;
    nTaskIdx     : USINT;
    nFlags       : BYTE;
    nDcTime      : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pWriteBuffer^.BufferFree >= 12 THEN
    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nEventType), 1);
    pWriteBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(hSpan), 1);
    pWriteBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nTaskIdx), 1);
    pWriteBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nFlags), 1);
    pWriteBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nDcTime), 8);
    pWriteBuffer^.DataAdded(8);
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_WriteFrameHeaderWithSpanId" Id="{6d7c5e46-f7a1-4c8f-b1e0-4f3d9c5a6b2d}">
      <Declaration><![CDATA[(* Phase 6 Stage 3: Write header with 8-byte span_id instead of 1-byte local_id.
   Used for ATTR, EVENT, END frames. Header layout:
   [event_type:u8] [span_id_byte0:u8] [task_idx:u8] [flags:u8] [dc_time:i64] [span_id_bytes1-7:7bytes] *)
METHOD PRIVATE _WriteFrameHeaderWithSpanId
VAR_INPUT
    pWriteBuffer : POINTER TO FB_LogBuffer;
    nEventType   : BYTE;
    abSpanId     : ARRAY[0..7] OF BYTE;
    nTaskIdx     : USINT;
    nFlags       : BYTE;
    nDcTime      : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pWriteBuffer^.BufferFree >= 20 THEN
    (* Event type *)
    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nEventType), 1);
    pWriteBuffer^.DataAdded(1);

    (* First byte of span_id (in place of former local_id) *)
    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(abSpanId[0]), 1);
    pWriteBuffer^.DataAdded(1);

    (* Task index *)
    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nTaskIdx), 1);
    pWriteBuffer^.DataAdded(1);

    (* Flags *)
    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nFlags), 1);
    pWriteBuffer^.DataAdded(1);

    (* DC time *)
    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nDcTime), 8);
    pWriteBuffer^.DataAdded(8);

    (* Remaining 7 bytes of span_id *)
    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(abSpanId[1]), 7);
    pWriteBuffer^.DataAdded(7);
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddBool" Id="{f026cfda-ccb5-4225-9dac-a2799fe5b6bd}">
      <Declaration><![CDATA[METHOD INTERNAL AddBool : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
    sKey  : STRING(30);
    bVal  : BOOL;
END_VAR
VAR
    nKeyLen    : UDINT;
    nKeyLenUsint : USINT;
    nDcTime    : LINT;
    nTaskIdx   : USINT;
    nValueType : BYTE := 3;
    pBuffer    : POINTER TO FB_LogBuffer;
    nTotalLen  : UDINT;
    byVal      : BYTE;
    nFlags     : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(20=12+8) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(1) *)
nTotalLen := 20 + 4 + nKeyLen + 1;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header with 8-byte span_id *)
    _WriteFrameHeaderWithSpanId(pBuffer, nEventTypeAttr, pSpan^._abSpanId, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* value_len for bool *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    byVal := BOOL_TO_BYTE(bVal);
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(byVal), 1);
    pBuffer^.DataAdded(1);

    AddBool := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddEvent" Id="{731c0681-f28c-468d-9a22-08d93456bc4b}">
      <Declaration><![CDATA[METHOD INTERNAL AddEvent : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
    sName : STRING(30);
END_VAR
VAR
    nNameLen    : UDINT;
    nNameLenUsint : USINT;
    nDcTime     : LINT;
    nTaskIdx    : USINT;
    nAttrCount  : BYTE := 0;
    pBuffer     : POINTER TO FB_LogBuffer;
    nTotalLen   : UDINT;
    nFlags      : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

nNameLen := Tc2_Utilities.LEN2(ADR(sName));
IF nNameLen > 31 THEN
    nNameLen := 31;
END_IF;
nNameLenUsint := TO_USINT(nNameLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(20=12+8) + name_len(1) + attr_count(1) + reserved(2) + name *)
nTotalLen := 20 + 4 + nNameLen;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header with 8-byte span_id *)
    _WriteFrameHeaderWithSpanId(pBuffer, nEventTypeEvent, pSpan^._abSpanId, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nNameLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nAttrCount), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nAttrCount), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nAttrCount), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nNameLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sName), nNameLen);
        pBuffer^.DataAdded(nNameLen);
    END_IF;

    AddEvent := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddInt" Id="{cebf7902-798a-47a4-b3e5-37d8ad80e0e0}">
      <Declaration><![CDATA[METHOD INTERNAL AddInt : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
    sKey  : STRING(30);
    nVal  : DINT;
END_VAR
VAR
    nKeyLen     : UDINT;
    nKeyLenUsint : USINT;
    nDcTime     : LINT;
    nTaskIdx    : USINT;
    nValueType  : BYTE := 1;
    pBuffer     : POINTER TO FB_LogBuffer;
    nTotalLen   : UDINT;
    nFlags      : BYTE := 0;
    nValLint    : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Widen DINT → LINT so the 8-byte wire field carries the full value
   instead of 4 bytes of stack garbage past the DINT. *)
nValLint := DINT_TO_LINT(nVal);

(* Frame: header(20=12+8) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(8) *)
nTotalLen := 20 + 4 + nKeyLen + 8;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header with 8-byte span_id *)
    _WriteFrameHeaderWithSpanId(pBuffer, nEventTypeAttr, pSpan^._abSpanId, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* value_len *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValLint), 8);
    pBuffer^.DataAdded(8);

    AddInt := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddLInt" Id="{40a748f6-c411-43f0-994d-38e870c92549}">
      <Declaration><![CDATA[METHOD INTERNAL AddLInt : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
    sKey  : STRING(30);
    nVal  : LINT;
END_VAR
VAR
    nKeyLen     : UDINT;
    nKeyLenUsint : USINT;
    nDcTime     : LINT;
    nTaskIdx    : USINT;
    nValueType  : BYTE := 1;
    pBuffer     : POINTER TO FB_LogBuffer;
    nTotalLen   : UDINT;
    nFlags      : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(20=12+8) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(8) *)
nTotalLen := 20 + 4 + nKeyLen + 8;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header with 8-byte span_id *)
    _WriteFrameHeaderWithSpanId(pBuffer, nEventTypeAttr, pSpan^._abSpanId, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* value_len *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nVal), 8);
    pBuffer^.DataAdded(8);

    AddLInt := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddReal" Id="{6a9dc70f-5325-45d1-8be5-172af842881e}">
      <Declaration><![CDATA[METHOD INTERNAL AddReal : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
    sKey  : STRING(30);
    fVal  : LREAL;
END_VAR
VAR
    nKeyLen     : UDINT;
    nKeyLenUsint : USINT;
    nDcTime     : LINT;
    nTaskIdx    : USINT;
    nValueType  : BYTE := 2;
    pBuffer     : POINTER TO FB_LogBuffer;
    nTotalLen   : UDINT;
    nFlags      : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(20=12+8) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(8) *)
nTotalLen := 20 + 4 + nKeyLen + 8;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header with 8-byte span_id *)
    _WriteFrameHeaderWithSpanId(pBuffer, nEventTypeAttr, pSpan^._abSpanId, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* value_len *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(fVal), 8);
    pBuffer^.DataAdded(8);

    AddReal := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddString" Id="{59a3fb41-a2f5-4bd0-ad49-dd002f212acc}">
      <Declaration><![CDATA[METHOD INTERNAL AddString : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
    sKey  : STRING(30);
    sVal  : STRING(120);
END_VAR
VAR
    nKeyLen      : UDINT;
    nKeyLenUsint : USINT;
    nValLen      : UDINT;
    nValLenUsint : USINT;
    nDcTime      : LINT;
    nTaskIdx     : USINT;
    nValueType   : BYTE := 4;
    pBuffer      : POINTER TO FB_LogBuffer;
    nTotalLen    : UDINT;
    nFlags       : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nValLen := Tc2_Utilities.LEN2(ADR(sVal));
IF nValLen > 127 THEN
    nValLen := 127;
END_IF;
nValLenUsint := TO_USINT(nValLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(20=12+8) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value *)
nTotalLen := 20 + 4 + nKeyLen + nValLen;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header with 8-byte span_id *)
    _WriteFrameHeaderWithSpanId(pBuffer, nEventTypeAttr, pSpan^._abSpanId, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    IF nValLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sVal), nValLen);
        pBuffer^.DataAdded(nValLen);
    END_IF;

    AddString := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Begin" Id="{832e89db-497a-4d07-b3b1-c6e95e2f7e46}">
      <Declaration><![CDATA[(*
:Description: INTERNAL — Mint IDs and emit SPAN_BEGIN frame for the given FB_Span.

Phase 6 Stage 3 refactored: FB_Span owns its trace_id and span_id. This method
populates them directly into the pSpan pointer. Parent trace_id is resolved
from sTraceParent (external) or minted fresh. parent_span_id must be supplied
by the caller (typically FB_TcOtelTracer._Begin, which reads its own
_pInnermost^._abSpanId or passes [0u8;8] for root).

Called only from FB_TcOtelTracer._Begin.
*)
METHOD INTERNAL Begin
VAR_INPUT
    pSpan          : POINTER TO FB_Span;
    sName          : STRING(60);
    eKind          : E_SpanKind := E_SpanKind.eInternal;
    sTraceParent   : STRING(60) := '';
    abParentSpanId : ARRAY[0..7] OF BYTE;
END_VAR
VAR
    nTaskIndex       : USINT;
    nNameLen         : UDINT;
    nNameLenUsint    : USINT;
    nTpLen           : UDINT;
    nTpLenUsint      : USINT;
    nFlagsBegin      : BYTE;
    nTotalLen        : UDINT;
    nDcTime          : LINT;
    pBuffer          : POINTER TO FB_LogBuffer;
    eKindByte        : BYTE;
    bExternalValid   : BOOL;
    abExternalSpanId : ARRAY[0..7] OF BYTE;
    bHasTraceId      : BOOL;
    i                : INT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

(* Seed RNG if not yet seeded *)
_SeedRng();

(* Resolution order mirrors Rust span_dispatcher.rs on_begin:
   1. External W3C traceparent     — adopt its trace_id
   2. Caller-populated _abTraceId  — bound-tracer inherit from parent
   3. True root                    — mint fresh trace_id
   span_id is always freshly minted. *)

bExternalValid := FALSE;
IF Tc2_Utilities.LEN2(ADR(sTraceParent)) > 0 THEN
    bExternalValid := _ParseTraceParent(sTraceParent,
                                         pSpan^._abTraceId,
                                         abExternalSpanId);
END_IF;

(* If external traceparent not valid, inspect whether caller already
   populated _abTraceId (instance-tracer inheriting from innermost open
   span). Mint fresh only when trace_id is still all zeros. *)
IF NOT bExternalValid THEN
    bHasTraceId := FALSE;
    FOR i := 0 TO 15 DO
        IF pSpan^._abTraceId[i] <> 0 THEN
            bHasTraceId := TRUE;
            EXIT;
        END_IF;
    END_FOR;
    IF NOT bHasTraceId THEN
        _MintTraceId(pSpan);
    END_IF;
END_IF;

(* Always mint a fresh span_id for this span *)
_MintSpanId(pSpan);

(* Prepare flags *)
nFlagsBegin := 0;
IF Tc2_Utilities.LEN2(ADR(sTraceParent)) > 0 THEN
    nFlagsBegin := nFlagsBegin OR 2;  (* flag_has_external_parent *)
END_IF;

(* Get current time and task index *)
nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIndex := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Prepare frame sizes *)
nNameLen := Tc2_Utilities.LEN2(ADR(sName));
IF nNameLen > 127 THEN
    nNameLen := 127;
END_IF;
nNameLenUsint := TO_USINT(nNameLen);

nTpLen := 0;
nTpLenUsint := 0;
IF (nFlagsBegin AND 2) <> 0 THEN
    nTpLen := Tc2_Utilities.LEN2(ADR(sTraceParent));
    IF nTpLen > 127 THEN
        nTpLen := 127;
    END_IF;
    nTpLenUsint := TO_USINT(nTpLen);
END_IF;

(* Total frame size: header(12) + parent_span_id(8) + kind(1) + name_len(1) + reserved(2)
   + trace_id(16) + span_id(8) + name + [if has_external_parent: tp_len(1) + tp] *)
nTotalLen := 12 + 8 + 4 + nNameLen;
IF (nFlagsBegin AND 2) <> 0 THEN
    nTotalLen := nTotalLen + 1 + nTpLen;
END_IF;

(* Write frame *)
pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header (12B) *)
    _WriteFrameHeader(pBuffer, nEventTypeBegin, 0, nTaskIndex, nFlagsBegin, nDcTime);

    (* parent_span_id (8B) *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(abParentSpanId[0]), 8);
    pBuffer^.DataAdded(8);

    (* kind (1B) *)
    eKindByte := TO_BYTE(eKind);
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(eKindByte), 1);
    pBuffer^.DataAdded(1);

    (* name_len (1B) *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nNameLenUsint), 1);
    pBuffer^.DataAdded(1);

    (* reserved (2B) *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nFlagsBegin), 2);
    pBuffer^.DataAdded(2);

    (* trace_id (16B) — always present *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(pSpan^._abTraceId[0]), 16);
    pBuffer^.DataAdded(16);

    (* span_id (8B) — always present *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(pSpan^._abSpanId[0]), 8);
    pBuffer^.DataAdded(8);

    (* name *)
    IF nNameLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sName), nNameLen);
        pBuffer^.DataAdded(nNameLen);
    END_IF;

    (* optional external traceparent *)
    IF (nFlagsBegin AND 2) <> 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nTpLenUsint), 1);
        pBuffer^.DataAdded(1);

        IF nTpLen > 0 THEN
            Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sTraceParent), nTpLen);
            pBuffer^.DataAdded(nTpLen);
        END_IF;
    END_IF;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Call" Id="{b918082d-1f06-4f72-b609-d97e60f0a088}">
      <Declaration><![CDATA[METHOD PUBLIC Call
(* No-op in Phase-1: wire events flushed on emission. *)
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="CurrentTraceParent" Id="{703b7f93-e680-4a9f-a268-bebc44b81a3d}">
      <Declaration><![CDATA[(*
:Description: Format a W3C traceparent header for the **innermost
open span of the task's span chain**.

Phase 6 Stage 3: reads directly from _pInnermost chain.

WARNING — task-global state. If two or more FB_Span instances hold
open spans on the same task at the same time (common for parallel
controllers), this returns whichever is innermost, not necessarily
the one the caller owns. Prefer the per-instance `FB_Span.TraceParent`
property instead.

`CurrentTraceParent` is still useful for nested-call contexts where
you know you are inside a single active span chain.

Returns '' when no span is open.
*)
METHOD PUBLIC CurrentTraceParent : STRING(60)
VAR
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF _pInnermost = 0 THEN
    CurrentTraceParent := '';
    RETURN;
END_IF;

CurrentTraceParent := _pInnermost^.TraceParent;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="End" Id="{82740a99-7e02-4458-aaa7-fef1872d30eb}">
      <Declaration><![CDATA[(*
:Description: INTERNAL — Emit SPAN_END frame for the given FB_Span.

Called only from FB_TcOtelTracer._End. Does not manage the tracer's chain —
that is the responsibility of FB_TcOtelTracer.
*)
METHOD INTERNAL End
VAR_INPUT
    pSpan : POINTER TO FB_Span;
END_VAR
VAR
    nTaskIdx   : USINT;
    nDcTime    : LINT;
    nStatus    : BYTE := 1;
    nMsgLen    : USINT := 0;
    pBuffer    : POINTER TO FB_LogBuffer;
    nTotalLen  : UDINT;
    nFlags     : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(20=12+8) + status(1) + msg_len(1) + reserved(2) *)
nTotalLen := 20 + 4;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header with 8-byte span_id *)
    _WriteFrameHeaderWithSpanId(pBuffer, nEventTypeEnd, pSpan^._abSpanId, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nStatus), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nMsgLen), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nMsgLen), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nMsgLen), 1);  (* reserved *)
    pBuffer^.DataAdded(1);
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetError" Id="{1323314a-5f82-499e-a923-f4a110bbfa07}">
      <Declaration><![CDATA[METHOD INTERNAL SetError : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
    sMsg  : STRING(120) := '';
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

(* Just acknowledge — FB_Span handles error state *)
SetError := TRUE;
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>