<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_TcOtelTaskTracer" Id="{294f80cd-71bb-4a49-ab79-358e75196d66}" SpecialFunc="None">
    <Declaration><![CDATA[(*
:Description: Per-task low-level OpenTelemetry trace wire transport.

INTERNAL — do not call directly from user code. One instance per task lives
in PRG_TaskLog.aTaskTracer. Wire-emit methods are called only by
FB_TcOtelTracer (the public instance-tracer API). Each method emits exactly
one wire event into the existing ADS write buffer (same path the logger uses).
Wire events are demuxed by tc-otel into a SpanEventDispatcher.

Emit path builds the fixed-size frame header on the stack, then writes it
to the send buffer in a single MEMCPY — followed by at most two MEMCPYs
for variable-length payload (key, value, name). BufferFree is checked once
up front; DataAdded commits the whole frame atomically.

Wire format documented in docs/traces-design.md Section "Wire Format".

Users should use FB_TcOtelTracer and FB_Span instead.
*)
{attribute 'no_explicit_call' := 'no direct call necessary'}
{attribute 'conditionalshow'}
FUNCTION_BLOCK FB_TcOtelTaskTracer
VAR
    (* Phase 6 Stage 3: innermost-open span chain. Spans register/unregister
       as they begin/end. NULL when no spans are open. *)
    _pInnermost      : POINTER TO FB_Span;

    (* Wire format event-type constants *)
    nEventTypeBegin  : BYTE := 5;
    nEventTypeAttr   : BYTE := 6;
    nEventTypeEvent  : BYTE := 7;
    nEventTypeEnd    : BYTE := 8;

    (* xorshift64 PRNG state used to mint W3C trace_id / span_id locally.
       Seeded on first Begin() call from the DC clock XOR the task index so
       separate tasks do not produce the same stream. OTel spec only
       requires randomly generated IDs — xorshift is sufficient and costs
       ~6 ops per 64-bit draw. *)
    _nXorState       : ULINT := 16#DEADBEEFCAFEF00D;
    _bRngSeeded      : BOOL  := FALSE;

    (* Monotonic span counter feeding the wire header's local_id field.
       Wraps at 255. Required so the tc-otel SpanKey — currently
       (net_id, task, local_id) — stays unique across concurrently open
       spans on the same task. Without this, multiple BEGINs share a
       SpanKey and each new BEGIN flushes the previous as "timed-out". *)
    _nNextLocalId    : USINT := 0;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="_GetTaskDcTime" Id="{9b32520a-c9fc-420a-8034-c0663bb4b6b9}">
      <Declaration><![CDATA[METHOD PRIVATE _GetTaskDcTime : LINT
VAR
    nTaskIdx : DINT;
    pTaskInfo : POINTER TO PlcTaskSystemInfo;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
nTaskIdx := Tc2_Utilities.GETCURTASKINDEXEX();
IF nTaskIdx > 0 AND nTaskIdx <= SIZEOF(TwinCAT_SystemInfoVarList._TaskInfo) / SIZEOF(PlcTaskSystemInfo) THEN
    pTaskInfo := ADR(TwinCAT_SystemInfoVarList._TaskInfo[nTaskIdx]);
    _GetTaskDcTime := pTaskInfo^.DcTaskTime;
ELSE
    _GetTaskDcTime := 0;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_NowDcTime" Id="{a1b2c3d4-e5f6-1111-2222-333344445555}">
      <Declaration><![CDATA[(* Return live DC time, falling back to cycle-start task DC time. *)
METHOD PRIVATE _NowDcTime : LINT
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
_NowDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF _NowDcTime = 0 THEN
    _NowDcTime := _GetTaskDcTime();
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SeedRng" Id="{1a8f2c4d-3b5e-4a6f-8d7c-9e0a1b2c3d4f}">
      <Declaration><![CDATA[METHOD PRIVATE _SeedRng
VAR
    nDcTime : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF _bRngSeeded THEN
    RETURN;
END_IF;

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;

(* XOR with task index so separate tasks can't produce the same stream
   if two of them seed within the same DC-time tick. Add the fallback
   constant so a zero DC clock still gives a non-zero seed (xorshift64
   requires non-zero state). *)
_nXorState := TO_ULINT(nDcTime) XOR (TO_ULINT(Tc2_Utilities.GETCURTASKINDEXEX()) * 16#9E3779B97F4A7C15);
IF _nXorState = 0 THEN
    _nXorState := 16#DEADBEEFCAFEF00D;
END_IF;

_bRngSeeded := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_NextRandom" Id="{2b9e3d5f-4c6a-4b7d-8e9f-0a1b2c3d4e5f}">
      <Declaration><![CDATA[(* xorshift64 (Marsaglia 2003): 6 ops, period 2^64 - 1, zero lookup tables. *)
METHOD PRIVATE _NextRandom : ULINT
VAR
    x : ULINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
x := _nXorState;
x := x XOR SHL(x, 13);
x := x XOR SHR(x, 7);
x := x XOR SHL(x, 17);
_nXorState := x;
_NextRandom := x;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_MintTraceId" Id="{3c0a4e6b-5d7c-4e8f-9a0b-1c2d3e4f5a6b}">
      <Declaration><![CDATA[(* Fills the 16-byte trace_id of the FB_Span with two xorshift64 draws. *)
METHOD PRIVATE _MintTraceId
VAR_INPUT
    pSpan : POINTER TO FB_Span;
END_VAR
VAR
    hi  : ULINT;
    lo  : ULINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

hi := _NextRandom();
lo := _NextRandom();
Tc2_System.MEMCPY(ADR(pSpan^._abTraceId[0]), ADR(hi), 8);
Tc2_System.MEMCPY(ADR(pSpan^._abTraceId[8]), ADR(lo), 8);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_MintSpanId" Id="{4d1b5f7c-6e8d-4f9a-0b1c-2d3e4f5a6b7c}">
      <Declaration><![CDATA[(* Fills the 8-byte span_id of the FB_Span with one xorshift64 draw. *)
METHOD PRIVATE _MintSpanId
VAR_INPUT
    pSpan : POINTER TO FB_Span;
END_VAR
VAR
    v : ULINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

v := _NextRandom();
Tc2_System.MEMCPY(ADR(pSpan^._abSpanId[0]), ADR(v), 8);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_HexCharToNibble" Id="{6a5b4c3d-2e1f-4a5b-8c7d-9e0f1a2b3c4d}">
      <Declaration><![CDATA[(* Convert one hex ASCII byte ('0'-'9', 'a'-'f', 'A'-'F') into a 4-bit nibble.
   Returns FALSE for any other byte. Used by _ParseTraceParent. *)
METHOD PRIVATE _HexCharToNibble : BOOL
VAR_INPUT
    ch : BYTE;
END_VAR
VAR_IN_OUT
    nNibble : BYTE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF ch >= 16#30 AND ch <= 16#39 THEN
    nNibble := ch - 16#30;                  (* '0'..'9' -> 0..9 *)
    _HexCharToNibble := TRUE;
ELSIF ch >= 16#61 AND ch <= 16#66 THEN
    nNibble := ch - 16#57;                  (* 'a'..'f' -> 10..15 *)
    _HexCharToNibble := TRUE;
ELSIF ch >= 16#41 AND ch <= 16#46 THEN
    nNibble := ch - 16#37;                  (* 'A'..'F' -> 10..15 *)
    _HexCharToNibble := TRUE;
ELSE
    _HexCharToNibble := FALSE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_ParseTraceParent" Id="{7b6c5d4e-3f2a-4b6c-9d8e-0f1a2b3c4d5e}">
      <Declaration><![CDATA[(* Parse a W3C traceparent string into raw trace_id (16B) and span_id (8B) bytes.
   Expected format: "00-<32 hex>-<16 hex>-<2 hex>", total 55 chars.
   Returns TRUE on success (abTraceId / abSpanId populated), FALSE on any
   validation failure. On failure, output arrays may be partially written —
   callers must treat FALSE as "ignore outputs". *)
METHOD PRIVATE _ParseTraceParent : BOOL
VAR_INPUT
    sTp : STRING(60);
END_VAR
VAR_IN_OUT
    abTraceId : ARRAY[0..15] OF BYTE;
    abSpanId  : ARRAY[0..7]  OF BYTE;
END_VAR
VAR
    pBytes : POINTER TO BYTE;
    i      : INT;
    nHi    : BYTE;
    nLo    : BYTE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
_ParseTraceParent := FALSE;

(* W3C traceparent is exactly 55 ASCII characters. *)
IF Tc2_Utilities.LEN2(ADR(sTp)) < 55 THEN
    RETURN;
END_IF;

pBytes := ADR(sTp);

(* Version "00" — other versions unrecognised, reject *)
IF pBytes[0] <> 16#30 OR pBytes[1] <> 16#30 THEN
    RETURN;
END_IF;

(* Delimiters at positions 2, 35, 52 *)
IF pBytes[2] <> 16#2D OR pBytes[35] <> 16#2D OR pBytes[52] <> 16#2D THEN
    RETURN;
END_IF;

(* Flags must be "00" (not sampled) or "01" (sampled). Other values are
   reserved; reject to stay conservative. *)
IF pBytes[53] <> 16#30 THEN
    RETURN;
END_IF;
IF pBytes[54] <> 16#30 AND pBytes[54] <> 16#31 THEN
    RETURN;
END_IF;

(* Decode trace_id: 32 hex chars at offset 3 -> 16 bytes *)
FOR i := 0 TO 15 DO
    IF NOT _HexCharToNibble(pBytes[3 + i * 2], nHi) THEN
        RETURN;
    END_IF;
    IF NOT _HexCharToNibble(pBytes[3 + i * 2 + 1], nLo) THEN
        RETURN;
    END_IF;
    abTraceId[i] := SHL(nHi, 4) OR nLo;
END_FOR;

(* Decode span_id: 16 hex chars at offset 36 -> 8 bytes *)
FOR i := 0 TO 7 DO
    IF NOT _HexCharToNibble(pBytes[36 + i * 2], nHi) THEN
        RETURN;
    END_IF;
    IF NOT _HexCharToNibble(pBytes[36 + i * 2 + 1], nLo) THEN
        RETURN;
    END_IF;
    abSpanId[i] := SHL(nHi, 4) OR nLo;
END_FOR;

_ParseTraceParent := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddAny" Id="{b1a2c3d4-e5f6-7a8b-9c0d-1e2f3a4b5c01}">
      <Declaration><![CDATA[(*
:Description: INTERNAL — Emit SPAN_ATTR frame for the given FB_Span.

Generic attribute emit path — dispatches on ``stArg.TypeClass`` to derive
wire-type byte, widen narrow integers to i64, and widen REAL to LREAL.
One stack-built frame struct, then MEMCPY header + MEMCPY key + MEMCPY value
= 3 MEMCPYs (plus the span_id-rest fill into the struct).

Supported IEC types:
 * BOOL                                  → wire type 3 (1 byte)
 * SINT/INT/DINT/LINT                    → wire type 1 (widened to 8 bytes)
 * USINT/UINT/UDINT/ULINT/BYTE/WORD/DWORD/LWORD
                                         → wire type 1 (widened to 8 bytes)
 * REAL/LREAL                            → wire type 2 (widened to 8 bytes)
 * STRING                                → wire type 4 (live length ≤127)

Other types (WSTRING, TIME, ARRAY, STRUCT, ENUM) are silently dropped —
add to the dispatch CASE when a consumer needs them.
*)
METHOD INTERNAL AddAny : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
    sKey  : STRING(30);
    stArg : ANY;
END_VAR
VAR
    stFrame        : ST_SpanAttrFrame;
    pBuffer        : POINTER TO FB_LogBuffer;
    pDst           : POINTER TO BYTE;
    nKeyLen        : UDINT;
    nValBytes      : UDINT;
    nTotalLen      : UDINT;
    pValueSrc      : POINTER TO BYTE;
    nWireType      : BYTE;
    (* Widening scratch — one field per wire-width so the type dispatch
       can hand AddAny a pointer to a stack LINT/ULINT/LREAL without
       aliasing the caller's storage. *)
    nValLint       : LINT;
    nValULint      : ULINT;
    fValLreal      : LREAL;
    byValBool      : BYTE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 OR_ELSE stArg.pValue = 0 THEN
    RETURN;
END_IF;

(* Key length — capped at 31 (Rust parser enforces ≤31) *)
nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;

(* Type dispatch: derive wire-type byte + pointer to value + byte count *)
CASE stArg.TypeClass OF
    __SYSTEM.TYPE_CLASS.TYPE_BOOL:
        nWireType := 3;
        IF Tc2_Utilities.PBYTE_TO_BYTE(stArg.pValue) <> 0 THEN
            byValBool := 1;
        ELSE
            byValBool := 0;
        END_IF;
        pValueSrc := ADR(byValBool);
        nValBytes := 1;

    __SYSTEM.TYPE_CLASS.TYPE_SINT:
        nWireType := 1;
        nValLint  := SINT_TO_LINT(Tc2_Utilities.PBYTE_TO_SINT(stArg.pValue));
        pValueSrc := ADR(nValLint);
        nValBytes := 8;

    __SYSTEM.TYPE_CLASS.TYPE_INT:
        nWireType := 1;
        nValLint  := INT_TO_LINT(Tc2_Utilities.PBYTE_TO_INT(stArg.pValue));
        pValueSrc := ADR(nValLint);
        nValBytes := 8;

    __SYSTEM.TYPE_CLASS.TYPE_DINT:
        nWireType := 1;
        nValLint  := DINT_TO_LINT(Tc2_Utilities.PBYTE_TO_DINT(stArg.pValue));
        pValueSrc := ADR(nValLint);
        nValBytes := 8;

    __SYSTEM.TYPE_CLASS.TYPE_LINT:
        nWireType := 1;
        pValueSrc := stArg.pValue;
        nValBytes := 8;

    __SYSTEM.TYPE_CLASS.TYPE_USINT,
    __SYSTEM.TYPE_CLASS.TYPE_BYTE:
        nWireType := 1;
        nValULint := USINT_TO_ULINT(Tc2_Utilities.PBYTE_TO_USINT(stArg.pValue));
        pValueSrc := ADR(nValULint);
        nValBytes := 8;

    __SYSTEM.TYPE_CLASS.TYPE_UINT,
    __SYSTEM.TYPE_CLASS.TYPE_WORD:
        nWireType := 1;
        nValULint := UINT_TO_ULINT(Tc2_Utilities.PBYTE_TO_UINT(stArg.pValue));
        pValueSrc := ADR(nValULint);
        nValBytes := 8;

    __SYSTEM.TYPE_CLASS.TYPE_UDINT,
    __SYSTEM.TYPE_CLASS.TYPE_DWORD:
        nWireType := 1;
        nValULint := UDINT_TO_ULINT(Tc2_Utilities.PBYTE_TO_UDINT(stArg.pValue));
        pValueSrc := ADR(nValULint);
        nValBytes := 8;

    __SYSTEM.TYPE_CLASS.TYPE_ULINT,
    __SYSTEM.TYPE_CLASS.TYPE_LWORD:
        nWireType := 1;
        pValueSrc := stArg.pValue;
        nValBytes := 8;

    __SYSTEM.TYPE_CLASS.TYPE_REAL:
        nWireType := 2;
        fValLreal := REAL_TO_LREAL(Tc2_Utilities.PBYTE_TO_REAL(stArg.pValue));
        pValueSrc := ADR(fValLreal);
        nValBytes := 8;

    __SYSTEM.TYPE_CLASS.TYPE_LREAL:
        nWireType := 2;
        pValueSrc := stArg.pValue;
        nValBytes := 8;

    __SYSTEM.TYPE_CLASS.TYPE_STRING:
        nWireType := 4;
        pValueSrc := stArg.pValue;
        nValBytes := Tc2_Utilities.LEN2(stArg.pValue);
        IF nValBytes > 127 THEN
            nValBytes := 127;
        END_IF;

ELSE
    (* Unsupported type — drop silently. Add to CASE above if needed. *)
    RETURN;
END_CASE;

(* Buffer capacity check — fixed header + key + value *)
nTotalLen := SIZEOF(stFrame) + nKeyLen + nValBytes;
pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer = 0 OR_ELSE pBuffer^.BufferFree < nTotalLen THEN
    RETURN;
END_IF;

(* Build frame header on stack (aligned) *)
stFrame.nEventType   := nEventTypeAttr;
stFrame.nSpanIdByte0 := pSpan^._abSpanId[0];
stFrame.nTaskIdx     := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());
stFrame.nFlags       := 0;
stFrame.nDcTime      := _NowDcTime();
Tc2_System.MEMCPY(ADR(stFrame.abSpanIdRest[0]), ADR(pSpan^._abSpanId[1]), 7);
stFrame.nValueType   := nWireType;
stFrame.nKeyLen      := TO_BYTE(nKeyLen);
stFrame.nValueLen    := TO_BYTE(nValBytes);
stFrame.nReserved    := 0;

(* Emit: 3 MEMCPYs — header, key, value *)
pDst := pBuffer^.BufferPtr;
Tc2_System.MEMCPY(pDst, ADR(stFrame), SIZEOF(stFrame));
IF nKeyLen > 0 THEN
    Tc2_System.MEMCPY(pDst + SIZEOF(stFrame), ADR(sKey), nKeyLen);
END_IF;
IF nValBytes > 0 THEN
    Tc2_System.MEMCPY(pDst + SIZEOF(stFrame) + nKeyLen, pValueSrc, nValBytes);
END_IF;

pBuffer^.DataAdded(nTotalLen);
AddAny := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddEvent" Id="{731c0681-f28c-468d-9a22-08d93456bc4b}">
      <Declaration><![CDATA[METHOD INTERNAL AddEvent : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
    sName : STRING(30);
END_VAR
VAR
    stFrame    : ST_SpanEventFrame;
    pBuffer    : POINTER TO FB_LogBuffer;
    pDst       : POINTER TO BYTE;
    nNameLen   : UDINT;
    nTotalLen  : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

nNameLen := Tc2_Utilities.LEN2(ADR(sName));
IF nNameLen > 31 THEN
    nNameLen := 31;
END_IF;

nTotalLen := SIZEOF(stFrame) + nNameLen;
pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer = 0 OR_ELSE pBuffer^.BufferFree < nTotalLen THEN
    RETURN;
END_IF;

stFrame.nEventType   := nEventTypeEvent;
stFrame.nSpanIdByte0 := pSpan^._abSpanId[0];
stFrame.nTaskIdx     := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());
stFrame.nFlags       := 0;
stFrame.nDcTime      := _NowDcTime();
Tc2_System.MEMCPY(ADR(stFrame.abSpanIdRest[0]), ADR(pSpan^._abSpanId[1]), 7);
stFrame.nNameLen     := TO_BYTE(nNameLen);
stFrame.nAttrCount   := 0;
stFrame.nReserved[0] := 0;
stFrame.nReserved[1] := 0;

pDst := pBuffer^.BufferPtr;
Tc2_System.MEMCPY(pDst, ADR(stFrame), SIZEOF(stFrame));
IF nNameLen > 0 THEN
    Tc2_System.MEMCPY(pDst + SIZEOF(stFrame), ADR(sName), nNameLen);
END_IF;

pBuffer^.DataAdded(nTotalLen);
AddEvent := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Begin" Id="{832e89db-497a-4d07-b3b1-c6e95e2f7e46}">
      <Declaration><![CDATA[(*
:Description: INTERNAL — Mint IDs and emit SPAN_BEGIN frame for the given FB_Span.

Phase 6 Stage 3 refactored: FB_Span owns its trace_id and span_id. This method
populates them directly into the pSpan pointer. Parent trace_id is resolved
from sTraceParent (external) or minted fresh. parent_span_id must be supplied
by the caller (typically FB_TcOtelTracer._Begin, which reads its own
_pInnermost^._abSpanId or passes [0u8;8] for root).

Called only from FB_TcOtelTracer._Begin.
*)
METHOD INTERNAL Begin
VAR_INPUT
    pSpan           : POINTER TO FB_Span;
    sName           : STRING(60);
    eKind           : E_SpanKind := E_SpanKind.eInternal;
    sTraceParent    : STRING(60) := '';
    abParentSpanId  : ARRAY[0..7] OF BYTE;
    bInheritTraceId : BOOL;
END_VAR
VAR
    stHdr            : ST_SpanBeginPrefix;
    pBuffer          : POINTER TO FB_LogBuffer;
    pDst             : POINTER TO BYTE;
    nNameLen         : UDINT;
    nTpLen           : UDINT;
    nTotalLen        : UDINT;
    nTailOffset      : UDINT;
    bExternalValid   : BOOL;
    abExternalSpanId : ARRAY[0..7] OF BYTE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

(* Seed RNG if not yet seeded *)
_SeedRng();

(* Resolution order mirrors Rust span_dispatcher.rs on_begin:
   1. External W3C traceparent     — adopt its trace_id
   2. Caller-populated _abTraceId  — bound-tracer inherit from parent
   3. True root                    — mint fresh trace_id
   span_id is always freshly minted. *)
bExternalValid := FALSE;
IF Tc2_Utilities.LEN2(ADR(sTraceParent)) > 0 THEN
    bExternalValid := _ParseTraceParent(sTraceParent,
                                         pSpan^._abTraceId,
                                         abExternalSpanId);
END_IF;

IF NOT bExternalValid AND NOT bInheritTraceId THEN
    _MintTraceId(pSpan);
END_IF;

_MintSpanId(pSpan);

(* Compute variable-length tails *)
nNameLen := Tc2_Utilities.LEN2(ADR(sName));
IF nNameLen > 127 THEN
    nNameLen := 127;
END_IF;

nTpLen := 0;
IF Tc2_Utilities.LEN2(ADR(sTraceParent)) > 0 THEN
    nTpLen := Tc2_Utilities.LEN2(ADR(sTraceParent));
    IF nTpLen > 127 THEN
        nTpLen := 127;
    END_IF;
END_IF;

(* Total size: 24B hdr + 16B trace_id + 8B span_id + name + [tp_len(1)+tp if external] *)
nTotalLen := SIZEOF(stHdr) + 16 + 8 + nNameLen;
IF nTpLen > 0 THEN
    nTotalLen := nTotalLen + 1 + nTpLen;
END_IF;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer = 0 OR_ELSE pBuffer^.BufferFree < nTotalLen THEN
    RETURN;
END_IF;

(* Build 24-byte fixed prefix on the stack *)
stHdr.nEventType  := nEventTypeBegin;
stHdr.nLocalId    := _nNextLocalId;
stHdr.nTaskIdx    := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());
IF nTpLen > 0 THEN
    stHdr.nFlags  := 2;   (* flag_has_external_parent *)
ELSE
    stHdr.nFlags  := 0;
END_IF;
stHdr.nDcTime     := _NowDcTime();
Tc2_System.MEMCPY(ADR(stHdr.abParentSpanId[0]), ADR(abParentSpanId[0]), 8);
stHdr.nKind       := TO_BYTE(eKind);
stHdr.nNameLen    := TO_BYTE(nNameLen);
stHdr.nReserved[0] := 0;
stHdr.nReserved[1] := 0;

_nNextLocalId := _nNextLocalId + 1;

(* Emit:
     [0..23]   stHdr
     [24..39]  trace_id (16 B)
     [40..47]  span_id  (8 B)
     [48..]    name
     optional: tp_len(1) + traceparent *)
pDst := pBuffer^.BufferPtr;
Tc2_System.MEMCPY(pDst, ADR(stHdr), SIZEOF(stHdr));
Tc2_System.MEMCPY(pDst + SIZEOF(stHdr),        ADR(pSpan^._abTraceId[0]), 16);
Tc2_System.MEMCPY(pDst + SIZEOF(stHdr) + 16,   ADR(pSpan^._abSpanId[0]),  8);

nTailOffset := SIZEOF(stHdr) + 24;
IF nNameLen > 0 THEN
    Tc2_System.MEMCPY(pDst + nTailOffset, ADR(sName), nNameLen);
END_IF;

IF nTpLen > 0 THEN
    (* tp_len as one byte, then tp bytes *)
    (pDst + nTailOffset + nNameLen)^ := TO_BYTE(nTpLen);
    Tc2_System.MEMCPY(pDst + nTailOffset + nNameLen + 1, ADR(sTraceParent), nTpLen);
END_IF;

pBuffer^.DataAdded(nTotalLen);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Call" Id="{b918082d-1f06-4f72-b609-d97e60f0a088}">
      <Declaration><![CDATA[METHOD PUBLIC Call
(* No-op in Phase-1: wire events flushed on emission. *)
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="CurrentTraceParent" Id="{703b7f93-e680-4a9f-a268-bebc44b81a3d}">
      <Declaration><![CDATA[(*
:Description: Format a W3C traceparent header for the **innermost
open span of the task's span chain**.

Phase 6 Stage 3: reads directly from _pInnermost chain.

WARNING — task-global state. If two or more FB_Span instances hold
open spans on the same task at the same time (common for parallel
controllers), this returns whichever is innermost, not necessarily
the one the caller owns. Prefer the per-instance `FB_Span.TraceParent`
property instead.

`CurrentTraceParent` is still useful for nested-call contexts where
you know you are inside a single active span chain.

Returns '' when no span is open.
*)
METHOD PUBLIC CurrentTraceParent : STRING(60)
VAR
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF _pInnermost = 0 THEN
    CurrentTraceParent := '';
    RETURN;
END_IF;

CurrentTraceParent := _pInnermost^.TraceParent;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="End" Id="{82740a99-7e02-4458-aaa7-fef1872d30eb}">
      <Declaration><![CDATA[(*
:Description: INTERNAL — Emit SPAN_END frame for the given FB_Span.

Called only from FB_TcOtelTracer._End. Does not manage the tracer's chain —
that is the responsibility of FB_TcOtelTracer.
*)
METHOD INTERNAL End
VAR_INPUT
    pSpan : POINTER TO FB_Span;
END_VAR
VAR
    stFrame  : ST_SpanEndFrame;
    pBuffer  : POINTER TO FB_LogBuffer;
    pDst     : POINTER TO BYTE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer = 0 OR_ELSE pBuffer^.BufferFree < SIZEOF(stFrame) THEN
    RETURN;
END_IF;

stFrame.nEventType   := nEventTypeEnd;
stFrame.nSpanIdByte0 := pSpan^._abSpanId[0];
stFrame.nTaskIdx     := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());
stFrame.nFlags       := 0;
stFrame.nDcTime      := _NowDcTime();
Tc2_System.MEMCPY(ADR(stFrame.abSpanIdRest[0]), ADR(pSpan^._abSpanId[1]), 7);
stFrame.nStatus      := 1;   (* 1 = ok; FB_Span overrides via SetError path *)
stFrame.nMsgLen      := 0;
stFrame.nReserved[0] := 0;
stFrame.nReserved[1] := 0;

pDst := pBuffer^.BufferPtr;
Tc2_System.MEMCPY(pDst, ADR(stFrame), SIZEOF(stFrame));

pBuffer^.DataAdded(SIZEOF(stFrame));
]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetError" Id="{1323314a-5f82-499e-a923-f4a110bbfa07}">
      <Declaration><![CDATA[METHOD INTERNAL SetError : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
    sMsg  : STRING(120) := '';
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

(* Just acknowledge — FB_Span handles error state *)
SetError := TRUE;
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>
