  <Itf Name="I_LogBuilder" Id="{7cc70285-5d0d-45bd-9ca5-5fc75d169d66}">
    <Declaration><![CDATA[// Fluent builder interface for composing log entries.
// Obtain an instance via F_Log() or FB_Log.Log(), chain methods, and call CreateLog() to emit.
INTERFACE I_LogBuilder EXTENDS I_WithContext, I_WithLogger
]]></Declaration>
  </Itf>
</TcPlcObject>