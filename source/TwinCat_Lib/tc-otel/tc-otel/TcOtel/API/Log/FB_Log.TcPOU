	.WithContext(fbLoggerContext);
]]></ST>
      </Implementation>
    </Method>
    <Property Name="LoggerContext" Id="{d4e5f6a7-b8c9-4d0e-1f2a-3b4c5d6e7f80}">
      <Declaration><![CDATA[// Persistent context properties attached to every log entry from this instance.
// Add properties once; they are automatically included in all subsequent Log() calls.
PROPERTY PUBLIC LoggerContext : I_ContextBuilder]]></Declaration>
      <Get Name="Get" Id="{e5f6a7b8-c9d0-4e1f-2a3b-4c5d6e7f8091}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[LoggerContext := fbLoggerContext;
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="Name" Id="{2f643616-5731-0fe9-2ea1-6dc2d4ac1d10}">
      <Declaration><![CDATA[PROPERTY Name : Tc2_System.T_MaxString]]></Declaration>
      <Get Name="Get" Id="{a87ad5af-4681-0352-3d4e-1b95e82ef46d}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[Name := sLogger;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{85fffd0f-bfee-08ac-1f60-573b71fb5603}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[sLogger := Name;]]></ST>
        </Implementation>
      </Set>
    </Property>
