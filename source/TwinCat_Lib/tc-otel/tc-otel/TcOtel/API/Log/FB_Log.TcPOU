<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_Log" Id="{a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d}" SpecialFunc="None">
    <Declaration><![CDATA[(*
:Description: Persistent logger with instance-scoped logger name and context.

Use this function block when you need a fixed logger name and/or persistent
context properties across multiple log calls. For one-off logging, use F_Log() instead.

The logger name is set during instantiation. Use the constant
``Const.sLoggerFromInstance`` to automatically derive the logger name
from the instance path (only works when instantiated inside a function block).

**Example**

.. code::
    VAR
        fbLog : FB_Log('Drives.Motor');
    END_VAR

    // Log with persistent logger name
    fbLog.Log(E_LogLevel.eInfo, 'Motor {0} started')
        .WithAnyArg(nMotorId)
        .CreateLog();

    // Set persistent context (set once, included in every log)
    fbLog.LoggerContext.AddDInt('MachineId', nMachineId);
*)
{attribute 'reflection'}
FUNCTION_BLOCK FB_Log
VAR
	{attribute 'instance-path'}
	{attribute 'noinit'}
	sInstancePath		: T_MaxString;
	sLogger				: T_MaxString;
	fbLoggerContext		: FB_ContextBuilder;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="Debug" Id="{7ec3435c-f466-0455-0509-0f75b3012c03}">
      <Declaration><![CDATA[// Creates a new log entry with the persistent logger name and context.
// Returns an I_LogBuilder for fluent chaining of arguments and additional context.
METHOD Debug : I_Logger
VAR_INPUT
	sMessage	: T_MaxString;
END_VAR
VAR
	builder : I_LogBuilder;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[

Debug := F_Log(E_LogLevel.eDebug, sMessage)
	.WithLogger(sLogger)
	.WithContext(fbLoggerContext);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Error" Id="{6b25f92e-161a-0899-3653-14cdc5ccac4b}">
      <Declaration><![CDATA[// Creates a new log entry with the persistent logger name and context.
// Returns an I_LogBuilder for fluent chaining of arguments and additional context.
