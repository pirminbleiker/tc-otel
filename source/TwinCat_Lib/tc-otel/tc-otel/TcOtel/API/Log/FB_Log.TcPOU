      </Implementation>
    </Method>
    <Method Name="FB_Init" Id="{3f6c08e7-45a5-034e-2d6b-ca66c6bcddb0}">
      <Declaration><![CDATA[//FB_Init is always available implicitly and it is used primarily for initialization.
//The return value is not evaluated. For a specific influence, you can also declare the
//methods explicitly and provide additional code there with the standard initialization
//code. You can evaluate the return value.
METHOD FB_Init: BOOL
VAR_INPUT
    bInitRetains: BOOL; // TRUE: the retain variables are initialized (reset warm / reset cold)
    bInCopyCode: BOOL;  // TRUE: the instance will be copied to the copy code afterward (online change)   
END_VAR
VAR
	nFindIdx	: INT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[nFindIdx := Tc2_Standard.FIND(sInstancePath, '.');
IF nFindIdx > 0 THEN
	sInstancePath := Tc2_Standard.DELETE(sInstancePath, nFindIdx + 1, 0);
	nFindIdx := Tc2_Standard.FIND(sInstancePath, '.');
	IF nFindIdx > 0 THEN
		sInstancePath := Tc2_Standard.DELETE(sInstancePath, nFindIdx + 1, 0);
		sLogger := sInstancePath;
	END_IF
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Info" Id="{c3d4e5f6-a7b8-4c9d-0e1f-2a3b4c5d6e7f}">
      <Declaration><![CDATA[// Creates a new log entry with the persistent logger name and context.
// Returns an I_LogBuilder for fluent chaining of arguments and additional context.
METHOD Info : I_Logger
VAR_INPUT
