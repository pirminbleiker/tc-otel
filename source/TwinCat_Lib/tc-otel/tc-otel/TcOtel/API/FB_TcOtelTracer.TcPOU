]]></ST>
      </Implementation>
    </Method>
    <Method Name="_AddString" Id="{c5a6b7c8-d9ea-6f70-910b-111d2e3f4a5b}">
      <Declaration><![CDATA[METHOD INTERNAL _AddString : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
