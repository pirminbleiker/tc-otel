]]></ST>
      </Implementation>
    </Method>
    <Method Name="_AddReal" Id="{b4f5a6b7-c8d9-6e7f-900a-111c2d3e4f5a}">
      <Declaration><![CDATA[METHOD INTERNAL _AddReal : BOOL
VAR_INPUT
