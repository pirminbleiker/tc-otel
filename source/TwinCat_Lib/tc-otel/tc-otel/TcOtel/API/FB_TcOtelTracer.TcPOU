<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_TcOtelTracer" Id="{d5e6f7a8-b9c0-4d1e-8f2a-3b4c5d6e7f8a}" SpecialFunc="None">
    <Declaration><![CDATA[(*
:Description: Instance-scoped trace emitter for isolating a
controller's span tree from parallel controllers on the same task.

Phase 6 — Stage 1. The task-scoped ``FB_TcOtelTaskTracer``
(accessed via ``PRG_TaskLog.Span``) remains the default. Bind an
instance of ``FB_TcOtelTracer`` to an ``FB_Span`` via
``FB_Span.BindTracer(myTracer)`` to get:

* **Isolated nesting.** Nested ``FB_Span.Begin`` under this tracer
  picks its parent from THIS tracer's own innermost-open span, not
  from the task-global ``aStack``. Two parallel controllers each
  with their own ``FB_TcOtelTracer`` can't poison each other's
  span trees.

* **Per-controller ``CurrentTraceParent``.** Reads the innermost
  span registered with this tracer, independent of any other
  tracers on the same task.

Wire emission still flows through the task tracer's log buffer
(we need a single outbound pipeline per task). local_ids are still
allocated task-wide. What differs is *which parent_local_id the
child cites* — that's driven by the tracer's own open-span stack,
not the task-global stack.

Internal structure: a single-linked LIFO stack of FB_Span pointers.
The tracer holds the innermost-open span; each span knows the one
it nested under (``_pOuterSpan`` on FB_Span). Begin pushes, End
pops. This matches the natural call-order guarantee users give:
Begin/End pairs are properly nested within any one controller.

Lifecycle:

.. code-block:: pascal

    VAR
        myTracer : FB_TcOtelTracer;
        spn      : FB_Span;
    END_VAR

    spn.BindTracer(myTracer);   // once, before first Begin
    spn.Begin('my_op');
    // ... work ...
    spn.End();

``FB_exit`` on the tracer is a safety net — walks the remaining
open stack and force-ends each span with ``status = eError`` so
tc-otel doesn't wait out the TTL.
*)
FUNCTION_BLOCK FB_TcOtelTracer
VAR
    (* Innermost (most-recently-begun) span bound to this tracer.
       NULL when no span is open. The chain walks via each span's
       _pOuterSpan pointer back to the first Begin. *)
    _pInnermost : POINTER TO FB_Span;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Property Name="CurrentTraceParent" Id="{28ef3f74-5ef1-043a-31b9-fe787251ccc3}">
      <Declaration><![CDATA[(*
:Description: W3C traceparent header for the innermost open span
bound to THIS tracer. '' when no span is open.

Unlike ``PRG_TaskLog.Span.CurrentTraceParent`` (task-global) this
property is scoped to the tracer instance. Two parallel controllers
each reading THEIR OWN tracer's CurrentTraceParent see their own
context — no race.
*)
PROPERTY PUBLIC CurrentTraceParent : STRING(60)]]></Declaration>
      <Get Name="Get" Id="{2cb861d5-bd5a-0f00-1e86-b27b7f81b4d0}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[
IF _pInnermost <> 0 THEN
    CurrentTraceParent := _pInnermost^.TraceParent;
ELSE
    CurrentTraceParent := '';
END_IF;
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="IsAnyOpen" Id="{f7a8b9c0-d1e2-4f3a-8b4c-5d6e7f8a9b0c}">
      <Declaration><![CDATA[(*
:Description: TRUE when at least one FB_Span bound to this tracer
is currently open. Useful for asserting a controller has cleanly
ended all its spans before proceeding.
*)
PROPERTY PUBLIC IsAnyOpen : BOOL]]></Declaration>
      <Get Name="Get" Id="{a8b9c0d1-e2f3-4a4b-9c5d-6e7f8a9b0c1d}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[IsAnyOpen := _pInnermost <> 0;
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="_RegisterOpen" Id="{b9c0d1e2-f3a4-4b5c-8d6e-7f8a9b0c1d2e}">
      <Declaration><![CDATA[(*
:Description: Internal — called by FB_Span.Begin right after the
wire BEGIN frame is emitted to push this span onto the tracer's
open stack. Must not be called by user code.
*)
METHOD INTERNAL _RegisterOpen
VAR_INPUT
    pSpan : POINTER TO FB_Span;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

(* Push: new span's outer = current top. New top = this span. *)
pSpan^._SetOuterSpan(_pInnermost);
_pInnermost := pSpan;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_UnregisterOpen" Id="{c0d1e2f3-a4b5-4c6d-8e7f-8a9b0c1d2e3f}">
      <Declaration><![CDATA[(*
:Description: Internal — called by FB_Span.End / FB_exit to pop this
span off the tracer's open stack. LIFO invariant: the span being
closed must be the innermost. Out-of-order closes are tolerated by
walking the outer-chain to detach the span; the remaining outer
spans keep their parents.

Must not be called by user code.
*)
METHOD INTERNAL _UnregisterOpen
VAR_INPUT
    pSpan : POINTER TO FB_Span;
END_VAR
VAR
    pCur : POINTER TO FB_Span;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

IF _pInnermost = pSpan THEN
    (* Common path: closing the innermost span. Pop. *)
    _pInnermost := pSpan^._GetOuterSpan();
    pSpan^._SetOuterSpan(0);
    RETURN;
END_IF;

(* Out-of-order close: find the span whose outer is pSpan, splice
   it out. If not found (pSpan is not on our stack), quiet no-op. *)
pCur := _pInnermost;
WHILE pCur <> 0 DO
    IF pCur^._GetOuterSpan() = pSpan THEN
        pCur^._SetOuterSpan(pSpan^._GetOuterSpan());
        pSpan^._SetOuterSpan(0);
        RETURN;
    END_IF;
    pCur := pCur^._GetOuterSpan();
END_WHILE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_Begin" Id="{c0a1b2c3-d4e5-6f7a-8b9c-0d1e2f3a4b5c}">
      <Declaration><![CDATA[(*
:Description: INTERNAL — Route FB_Span.Begin through the task tracer's wire emitter.

Resolves parent from _pInnermost (if not overridden by external sTraceParent),
then calls PRG_TaskLog.TaskTracer.Begin with the resolved parent_span_id.

Must only be called from FB_Span.Begin.
*)
METHOD INTERNAL _Begin : BOOL
VAR_INPUT
    pSpan        : POINTER TO FB_Span;
    sName        : STRING(60);
    eKind        : E_SpanKind := E_SpanKind.eInternal;
    sTraceParent : STRING(60) := '';
END_VAR
VAR
    abParentSpanId : ARRAY[0..7] OF BYTE;
    i              : INT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

(* Initialize parent_span_id to all-zero (root) *)
FOR i := 0 TO 7 DO
    abParentSpanId[i] := 16#00;
END_FOR;

(* If no external traceparent and tracer has an open span, inherit its span_id as parent *)
IF sTraceParent = '' AND _pInnermost <> 0 THEN
    Tc2_System.MEMCPY(ADR(abParentSpanId[0]),
                      ADR(_pInnermost^._abSpanId[0]),
                      8);
END_IF;

(* Call task tracer with resolved parent_span_id *)
PRG_TaskLog.TaskTracer.Begin(pSpan, sName, eKind, sTraceParent, abParentSpanId);
_Begin := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_End" Id="{d0b1c2d3-e4f5-6a7b-8c9d-0e1f2a3b4c5d}">
      <Declaration><![CDATA[(*
:Description: INTERNAL — Route FB_Span.End through the task tracer's wire emitter.

Called after FB_Span.End finishes its unregister logic on the instance tracer.

Must only be called from FB_Span.End.
*)
METHOD INTERNAL _End : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

PRG_TaskLog.TaskTracer.End(pSpan);
_End := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_AddBool" Id="{e1c2d3e4-f5a6-6b7c-8d9e-0f101a2b3c4d}">
      <Declaration><![CDATA[METHOD INTERNAL _AddBool : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
    sKey  : STRING(30);
    bVal  : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pSpan = 0 THEN
    RETURN;
END_IF;

_AddBool := PRG_TaskLog.TaskTracer.AddBool(pSpan, sKey, bVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_AddInt" Id="{f2d3e4f5-a6b7-6c7d-8e9f-100a1b2c3d4e}">
      <Declaration><![CDATA[METHOD INTERNAL _AddInt : BOOL
VAR_INPUT
