]]></ST>
      </Implementation>
    </Method>
    <Method Name="_AddLInt" Id="{a3e4f5a6-b7c8-6d7e-8f90-101b2c3d4e5f}">
      <Declaration><![CDATA[METHOD INTERNAL _AddLInt : BOOL
VAR_INPUT
