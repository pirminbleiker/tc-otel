]]></ST>
      </Implementation>
    </Method>
    <Method Name="_AddEvent" Id="{d6b7c8d9-eafb-7071-911c-111e2f3a4b5c}">
      <Declaration><![CDATA[METHOD INTERNAL _AddEvent : BOOL
VAR_INPUT
    pSpan : POINTER TO FB_Span;
