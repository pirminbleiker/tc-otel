    nVal : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddLInt := PRG_TaskLog.Span.AddLInt(_hSpan, sKey, nVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddReal" Id="{a24a3b0f-f308-4262-9e57-bd89b35d3e2f}">
      <Declaration><![CDATA[METHOD PUBLIC AddReal : BOOL
VAR_INPUT
    sKey : STRING(30);
    fVal : LREAL;
END_VAR
]]></Declaration>
      <Implementation>
