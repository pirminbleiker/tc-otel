<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_Span" Id="{d4dc3c52-ea23-461f-8f60-dd1c2fb8afd3}" SpecialFunc="None">
    <Declaration><![CDATA[(*
:Description: User-facing OOP trace span object.

Pure OOP interface (no VAR_INPUT / VAR_OUTPUT, no body call). Users declare
one FB_Span per logical operation and bind it to an FB_TcOtelTracer via
BindTracer, then drive it through method calls. The FB owns the span lifetime,
enforces begin/end pairing, and provides FB_exit safety net for abnormal
teardown (online change, program stop, FB deletion).

All methods delegate through the bound tracer's internal _* methods, which
route to the low-level task tracer for wire emission. Instance isolation is
achieved by each tracer maintaining its own open-span LIFO chain.

Documented in docs/traces-design.md Section "User-facing API: FB_Span".
*)
FUNCTION_BLOCK FB_Span
VAR
    _bOpen   : BOOL;
    _eStatus : E_SpanStatus := E_SpanStatus.eOk;
    _sMsg    : STRING(80);

    (* Phase 6 — Stage 1: optional instance tracer binding.
       NULL (default) → route through the task-global tracer
       (PRG_TaskLog.Span) — identical behaviour to Phase 5.
       Non-NULL → this FB_Span participates in the bound tracer's
       own open-span stack for parent resolution and
       CurrentTraceParent, isolating it from parallel FB_Spans on
       the same task. Set once via BindTracer before first Begin. *)
    _pTracer    : REFERENCE TO FB_TcOtelTracer;

    (* Pointer to the span that was the tracer's innermost-open span
       at the moment THIS span's Begin() ran. Forms the outer-chain
       used by FB_TcOtelTracer's LIFO stack. NULL when this is the
       outermost open span on the bound tracer (or when unbound).
       Accessed only via _GetOuterSpan / _SetOuterSpan below. *)
    _pOuterSpan : POINTER TO FB_Span;

    (* Phase 6 — Stage 3: span state owned by FB_Span, not in tracer slot.
       Trace_id and span_id bytes. Populated during Begin().
       TraceParent property computes directly from these. *)
    _abTraceId : ARRAY[0..15] OF BYTE;
    _abSpanId  : ARRAY[0..7] OF BYTE;
END_VAR
(*
Body empty — all work happens in methods that delegate to PRG_TaskLog.Span.
*)
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="_GetOuterSpan" Id="{f4a5b6c7-d8e9-4f0a-1b2c-3d4e5f6a7b8c}">
      <Declaration><![CDATA[(*
:Description: Internal accessor used by FB_TcOtelTracer to walk its
LIFO stack. Returns the span that was innermost-open when THIS span
began — or 0 if this is the outermost / unbound. Not user-visible.
*)
METHOD INTERNAL _GetOuterSpan : POINTER TO FB_Span
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_GetOuterSpan := _pOuterSpan;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SetOuterSpan" Id="{b6c7d8e9-f0a1-4b2c-3d4e-5f6a7b8c9d0e}">
      <Declaration><![CDATA[(*
:Description: Internal mutator used by FB_TcOtelTracer to attach
and detach this span from its LIFO stack. Not user-visible.
*)
METHOD INTERNAL _SetOuterSpan
VAR_INPUT
    pOuter : POINTER TO FB_Span;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_pOuterSpan := pOuter;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddAny" Id="{35782da4-c35d-0eed-09ec-3a5712bae02f}">
      <Declaration><![CDATA[(*
:Description: Emit a span attribute for any supported IEC 61131-3 scalar type.

Accepts BOOL, SINT/INT/DINT/LINT (signed), USINT/UINT/UDINT/ULINT/BYTE/WORD/
DWORD/LWORD (unsigned), REAL/LREAL, STRING. Narrow ints widen to i64, REAL
widens to f64 — consumers see uniform 8-byte numeric attrs.

Prefer AddAny for new code; the typed AddBool/AddInt/... variants are thin
shims kept for API back-compat.
*)
METHOD PUBLIC AddAny : BOOL
VAR_INPUT
    sKey  : STRING(30);
    stArg : ANY;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddAny := _pTracer._AddAny(THIS, sKey, stArg);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddBool" Id="{7047bbb4-5514-432f-96ef-1c5e7401f9b0}">
      <Declaration><![CDATA[METHOD PUBLIC AddBool : BOOL
VAR_INPUT
    sKey : STRING(30);
    bVal : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
AddBool := AddAny(sKey, bVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddEvent" Id="{5961eda2-89a9-4de6-a2cd-1b100a56d448}">
      <Declaration><![CDATA[METHOD PUBLIC AddEvent : BOOL
VAR_INPUT
    sName : STRING(30);
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddEvent := _pTracer._AddEvent(THIS, sName);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddInt" Id="{f0df946a-c020-44fb-9633-ae731bdcc31e}">
      <Declaration><![CDATA[METHOD PUBLIC AddInt : BOOL
VAR_INPUT
    sKey : STRING(30);
    nVal : DINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
AddInt := AddAny(sKey, nVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddLInt" Id="{2614a491-051f-464e-ac59-f521c4e3bb3f}">
      <Declaration><![CDATA[METHOD PUBLIC AddLInt : BOOL
VAR_INPUT
    sKey : STRING(30);
    nVal : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
AddLInt := AddAny(sKey, nVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddReal" Id="{a24a3b0f-f308-4262-9e57-bd89b35d3e2f}">
      <Declaration><![CDATA[METHOD PUBLIC AddReal : BOOL
VAR_INPUT
    sKey : STRING(30);
    fVal : LREAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
AddReal := AddAny(sKey, fVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddString" Id="{e5a80632-e29a-400a-9af6-015872718f9c}">
      <Declaration><![CDATA[METHOD PUBLIC AddString : BOOL
VAR_INPUT
    sKey : STRING(30);
    sVal : STRING(120);
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
AddString := AddAny(sKey, sVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Begin" Id="{2e739ce8-316c-49f6-966f-716f08f6881f}">
      <Declaration><![CDATA[(*
:Description: Start a new span on this FB_Span instance.

REQUIRES: BindTracer must be called first. If not, Begin logs an error and returns FALSE.

Pass `sTraceParent` to chain this span onto an incoming W3C traceparent
header — used for cross-task, cross-PLC, or cross-process propagation.
Leave empty for locally-rooted spans (the common case).

When `sTraceParent` is empty, the tracer's innermost open span is auto-used
as the parent. This gives each tracer its own isolated nesting chain, immune
to parallel spans on the same task.
*)
METHOD PUBLIC Begin : BOOL
VAR_INPUT
    sName        : STRING(60);
    eKind        : E_SpanKind := E_SpanKind.eInternal;
    sTraceParent : STRING(60) := '';
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Guard: BindTracer is now REQUIRED *)
IF NOT __ISVALIDREF(_pTracer) THEN
    F_InternalLog(
        eLogLevel := E_LogLevel.eError,
        sMessageFmt   := 'FB_Span.Begin called without BindTracer — span skipped',
		stArg1 := Tc2_Utilities.EMPTY_ARG_VALUE,
		stArg2 := Tc2_Utilities.EMPTY_ARG_VALUE,
		stArg3 := Tc2_Utilities.EMPTY_ARG_VALUE,
		stArg4 := Tc2_Utilities.EMPTY_ARG_VALUE);
    RETURN;
END_IF;

(* If already open, close the old span with error before starting the new one *)
IF _bOpen THEN
    _eStatus := E_SpanStatus.eError;
    _sMsg := 'span.begin called twice without end';
    End();
    RETURN;
END_IF;

(* Route through the bound tracer's _Begin method, which resolves
   parent and calls the task tracer. *)
_pTracer._Begin(THIS, sName, eKind, sTraceParent);

(* Mark open and reset status *)
_bOpen := TRUE;
_eStatus := E_SpanStatus.eOk;
_sMsg := '';

(* Register with the bound tracer so CurrentTraceParent and
   future nested Begin calls can see us. *)
_pTracer._RegisterOpen(THIS);

Begin := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="BindTracer" Id="{e3f4a5b6-c7d8-4e9f-0a1b-2c3d4e5f6a7b}">
      <Declaration><![CDATA[(*
:Description: Route this FB_Span through the supplied instance
tracer instead of the task-global default.

Must be called **before** the first ``Begin()``. Rebinding while the
span is open is rejected (keeps the tracer's linked list consistent).

Pass ``0`` (NULL) to unbind and revert to task-scoped behaviour.

Typical usage — one tracer per controller:

.. code-block:: pascal

    FUNCTION_BLOCK FB_Motion
    VAR
        _tracer : FB_TcOtelTracer;
        _spn    : FB_Span;
    END_VAR

    // in FB_init or first-cycle init:
    _spn.BindTracer(_tracer);
*)
METHOD PUBLIC BindTracer : BOOL
VAR_INPUT
    pTracer : REFERENCE TO FB_TcOtelTracer;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF _bOpen THEN
    (* Rebinding mid-span would strand this FB on the old tracer's
       list. Reject to keep the invariant clean. *)
    BindTracer := FALSE;
    RETURN;
END_IF;

_pTracer REF= pTracer;
BindTracer := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="End" Id="{5c4766aa-b8e0-4102-b1bb-60c9dbdaddcd}">
      <Declaration><![CDATA[METHOD PUBLIC End : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

(* If status is Error, pass the error message through *)
IF _eStatus = E_SpanStatus.eError THEN
    _pTracer._SetError(THIS, _sMsg);
END_IF;

(* End the span via the tracer's wire emitter *)
_pTracer._End(THIS);

(* Unregister from the bound tracer's open stack BEFORE clearing
   state, so the tracer's _UnregisterOpen can still read our
   _pOuterSpan to splice the LIFO chain. *)
_pTracer._UnregisterOpen(THIS);

(* Clear state *)
_bOpen := FALSE;
_eStatus := E_SpanStatus.eOk;
_sMsg := '';

End := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_exit" Id="{c5f30d75-e9bd-4c36-a9ef-80d3cbbac98f}">
      <Declaration><![CDATA[METHOD FB_exit : BOOL
VAR_INPUT
    bInCopyCode : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* If the span is still open and we're not in copy code (i.e., the FB is
   being destroyed), close it with an error so tc-otel doesn't wait out
   the TTL. End() handles unregistering from any bound tracer. *)
IF _bOpen AND NOT bInCopyCode THEN
    _eStatus := E_SpanStatus.eError;
    _sMsg := 'FB_Span instance destroyed while open';
    End();
END_IF;

FB_exit := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_Init" Id="{7ed89bcf-f585-01e2-31b6-c7f588f02318}">
      <Declaration><![CDATA[//FB_Init is always available implicitly and it is used primarily for initialization.
//The return value is not evaluated. For a specific influence, you can also declare the
//methods explicitly and provide additional code there with the standard initialization
//code. You can evaluate the return value.
METHOD FB_Init: BOOL
VAR_INPUT
    bInitRetains: BOOL; // TRUE: the retain variables are initialized (reset warm / reset cold)
    bInCopyCode: BOOL;  // TRUE: the instance will be copied to the copy code afterward (online change)   
    pTracer : REFERENCE TO FB_TcOtelTracer := 0;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF _bOpen THEN
    (* Rebinding mid-span would strand this FB on the old tracer's
       list. Reject to keep the invariant clean. *)
    FB_Init := FALSE;
    RETURN;
END_IF;

_pTracer REF= pTracer;
FB_Init := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Property Name="IsOpen" Id="{d47454d0-966d-4ff4-9068-ccbe2c845e9f}">
      <Declaration><![CDATA[PROPERTY PUBLIC IsOpen : BOOL]]></Declaration>
      <Get Name="Get" Id="{313caace-5095-4944-9c48-f70f3e3d5d5b}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[IsOpen := _bOpen;
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="MarkError" Id="{b332727a-e81d-4487-b536-326bafc3658f}">
      <Declaration><![CDATA[METHOD PUBLIC MarkError : BOOL
VAR_INPUT
    sMsg : STRING(80);
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

_eStatus := E_SpanStatus.eError;
_sMsg := sMsg;

MarkError := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Property Name="Status" Id="{654e2be9-7d52-4f77-b4d9-4454dea8c37a}">
      <Declaration><![CDATA[PROPERTY PUBLIC Status : E_SpanStatus]]></Declaration>
      <Get Name="Get" Id="{b0dd4378-a58c-424b-b99b-92ed5e77b1a1}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[Status := _eStatus;
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="TraceParent" Id="{af2b1e5c-3d4e-4f5a-8b6c-7d8e9f0a1b2c}">
      <Declaration><![CDATA[(*
:Description: W3C traceparent header for THIS span instance.

Returns ``00-<32hex>-<16hex>-01`` citing this instance's own
trace_id and span_id. Returns '' when the span is not open.

Unlike ``PRG_TaskLog.Span.CurrentTraceParent()`` which reads the
task-global span stack, this property is per-instance: parallel
FB_Span instances on the same task each return their OWN context.
Use this when shipping a traceparent across task, PLC, or transport
boundaries — it never picks up a span opened by a different
controller FB running on the same task.

Phase 6 Stage 3: now computes directly from _abTraceId / _abSpanId
owned by this FB_Span, no tracer indirection.
*)
PROPERTY PUBLIC TraceParent : STRING(60)]]></Declaration>
      <Get Name="Get" Id="{bc3d2f7e-4a5b-4c6d-9e8f-0a1b2c3d4e5f}">
        <Declaration><![CDATA[VAR
    i         : INT;
    nNibble   : BYTE;
    achHex    : ARRAY[0..15] OF BYTE := [16#30, 16#31, 16#32, 16#33, 16#34, 16#35, 16#36, 16#37, 16#38, 16#39, 16#61, 16#62, 16#63, 16#64, 16#65, 16#66];
    achOut    : ARRAY[0..55] OF BYTE;
    sHex      : STRING(60);
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[
IF NOT _bOpen THEN
    TraceParent := '';
    RETURN;
END_IF;

(* Layout: "00-" (3) + trace_id_hex (32) + "-" (1) + span_id_hex (16) + "-01" (3) = 55 chars *)
achOut[0] := 16#30;  (* '0' *)
achOut[1] := 16#30;  (* '0' *)
achOut[2] := 16#2D;  (* '-' *)

FOR i := 0 TO 15 DO
    nNibble := SHR(_abTraceId[i], 4) AND 16#0F;
    achOut[3 + i * 2]     := achHex[nNibble];
    nNibble := _abTraceId[i] AND 16#0F;
    achOut[3 + i * 2 + 1] := achHex[nNibble];
END_FOR

achOut[35] := 16#2D;  (* '-' *)

FOR i := 0 TO 7 DO
    nNibble := SHR(_abSpanId[i], 4) AND 16#0F;
    achOut[36 + i * 2]     := achHex[nNibble];
    nNibble := _abSpanId[i] AND 16#0F;
    achOut[36 + i * 2 + 1] := achHex[nNibble];
END_FOR

achOut[52] := 16#2D;  (* '-' *)
achOut[53] := 16#30;  (* '0' *)
achOut[54] := 16#31;  (* '1' *)

Tc2_System.MEMCPY(ADR(sHex), ADR(achOut[0]), 55);
sHex[55] := 0;
TraceParent := sHex;
]]></ST>
        </Implementation>
      </Get>
    </Property>
  </POU>
</TcPlcObject>