<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <DUT Name="E_SpanStatus" Id="{0b7d35f6-4ca9-4690-a3c2-317ac1a71837}">
    <Declaration><![CDATA[(*
:Description: Span completion status for OpenTelemetry traces.
*)
TYPE E_SpanStatus :
(
    eUnset := 0,  (* Unset status *)
    eOk    := 1,  (* Operation succeeded *)
    eError := 2   (* Operation failed *)
) USINT;
END_TYPE
]]></Declaration>
  </DUT>
</TcPlcObject>