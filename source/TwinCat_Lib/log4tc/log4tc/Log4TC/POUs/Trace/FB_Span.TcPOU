<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_Span" Id="{d4dc3c52-ea23-461f-8f60-dd1c2fb8afd3}" SpecialFunc="None">
    <Declaration><![CDATA[(*
:Description: User-facing OOP trace span object.

Pure OOP interface (no VAR_INPUT / VAR_OUTPUT, no body call). Users declare
one FB_Span per logical operation and drive it through method calls. The FB
owns the span lifetime, enforces begin/end pairing, and provides FB_exit
safety net for abnormal teardown (online change, program stop, FB deletion).

All methods delegate to PRG_TaskLog.Span (the low-level FB_Log4TcTaskTracer
instance for the current task).

Documented in docs/traces-design.md Section "User-facing API: FB_Span".
*)
FUNCTION_BLOCK FB_Span
VAR
    _hSpan   : USINT;
    _bOpen   : BOOL;
    _eStatus : E_SpanStatus := E_SpanStatus.eOk;
    _sMsg    : STRING(80);
END_VAR
(*
Body empty — all work happens in methods that delegate to PRG_TaskLog.Span.
*)
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="AddBool" Id="{7047bbb4-5514-432f-96ef-1c5e7401f9b0}">
      <Declaration><![CDATA[METHOD PUBLIC AddBool : BOOL
VAR_INPUT
    sKey : STRING(30);
    bVal : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddBool := PRG_TaskLog.Span.AddBool(_hSpan, sKey, bVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddEvent" Id="{5961eda2-89a9-4de6-a2cd-1b100a56d448}">
      <Declaration><![CDATA[METHOD PUBLIC AddEvent : BOOL
VAR_INPUT
    sName : STRING(30);
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddEvent := PRG_TaskLog.Span.AddEvent(_hSpan, sName);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddInt" Id="{f0df946a-c020-44fb-9633-ae731bdcc31e}">
      <Declaration><![CDATA[METHOD PUBLIC AddInt : BOOL
VAR_INPUT
    sKey : STRING(30);
    nVal : DINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddInt := PRG_TaskLog.Span.AddInt(_hSpan, sKey, nVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddLInt" Id="{2614a491-051f-464e-ac59-f521c4e3bb3f}">
      <Declaration><![CDATA[METHOD PUBLIC AddLInt : BOOL
VAR_INPUT
    sKey : STRING(30);
    nVal : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddLInt := PRG_TaskLog.Span.AddLInt(_hSpan, sKey, nVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddReal" Id="{a24a3b0f-f308-4262-9e57-bd89b35d3e2f}">
      <Declaration><![CDATA[METHOD PUBLIC AddReal : BOOL
VAR_INPUT
    sKey : STRING(30);
    fVal : LREAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddReal := PRG_TaskLog.Span.AddReal(_hSpan, sKey, fVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddString" Id="{e5a80632-e29a-400a-9af6-015872718f9c}">
      <Declaration><![CDATA[METHOD PUBLIC AddString : BOOL
VAR_INPUT
    sKey : STRING(30);
    sVal : STRING(120);
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddString := PRG_TaskLog.Span.AddString(_hSpan, sKey, sVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Begin" Id="{2e739ce8-316c-49f6-966f-716f08f6881f}">
      <Declaration><![CDATA[METHOD PUBLIC Begin : BOOL
VAR_INPUT
    sName : STRING(60);
    eKind : E_SpanKind := E_SpanKind.eInternal;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* If already open, close the old span with error before starting the new one *)
IF _bOpen THEN
    _eStatus := E_SpanStatus.eError;
    _sMsg := 'span.begin called twice without end';
    End();
END_IF;

(* Begin a new span on the task tracer *)
_hSpan := PRG_TaskLog.Span.Begin(sName, eKind, '');

(* Mark open and reset status *)
_bOpen := TRUE;
_eStatus := E_SpanStatus.eOk;
_sMsg := '';

Begin := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="End" Id="{5c4766aa-b8e0-4102-b1bb-60c9dbdaddcd}">
      <Declaration><![CDATA[METHOD PUBLIC End : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

(* If status is Error, pass the error message to the tracer *)
IF _eStatus = E_SpanStatus.eError THEN
    PRG_TaskLog.Span.SetError(_hSpan, _sMsg);
END_IF;

(* End the span *)
PRG_TaskLog.Span.End(_hSpan);

(* Clear state *)
_bOpen := FALSE;
_hSpan := 0;
_eStatus := E_SpanStatus.eOk;
_sMsg := '';

End := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_exit" Id="{c5f30d75-e9bd-4c36-a9ef-80d3cbbac98f}">
      <Declaration><![CDATA[METHOD FB_exit : BOOL
VAR_INPUT
    bInCopyCode : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* If the span is still open and we're not in copy code (i.e., the FB is
   being destroyed), close it with an error so tc-otel doesn't wait out
   the TTL. *)
IF _bOpen AND NOT bInCopyCode THEN
    _eStatus := E_SpanStatus.eError;
    _sMsg := 'FB_Span instance destroyed while open';
    End();
END_IF;

FB_exit := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Property Name="Handle" Id="{56f68b38-eaef-45f0-9c31-34dc46c965b8}">
      <Declaration><![CDATA[PROPERTY PUBLIC Handle : USINT]]></Declaration>
      <Get Name="Get" Id="{fee58c78-ec10-452f-9c15-5fc5863251c7}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[Handle := _hSpan;
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="IsOpen" Id="{d47454d0-966d-4ff4-9068-ccbe2c845e9f}">
      <Declaration><![CDATA[PROPERTY PUBLIC IsOpen : BOOL]]></Declaration>
      <Get Name="Get" Id="{313caace-5095-4944-9c48-f70f3e3d5d5b}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[IsOpen := _bOpen;
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="MarkError" Id="{b332727a-e81d-4487-b536-326bafc3658f}">
      <Declaration><![CDATA[METHOD PUBLIC MarkError : BOOL
VAR_INPUT
    sMsg : STRING(80);
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

_eStatus := E_SpanStatus.eError;
_sMsg := sMsg;

MarkError := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Property Name="Status" Id="{654e2be9-7d52-4f77-b4d9-4454dea8c37a}">
      <Declaration><![CDATA[PROPERTY PUBLIC Status : E_SpanStatus]]></Declaration>
      <Get Name="Get" Id="{b0dd4378-a58c-424b-b99b-92ed5e77b1a1}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[Status := _eStatus;
]]></ST>
        </Implementation>
      </Get>
    </Property>
  </POU>
</TcPlcObject>