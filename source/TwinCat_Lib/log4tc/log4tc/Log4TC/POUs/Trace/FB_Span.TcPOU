<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_Span" Id="{e7f8a9b0-c1d2-43w4-x5y6-z7a8b9c0d1e2}" SpecialFunc="None">
    <Declaration><![CDATA[(*
:Description: User-facing OOP trace span object.

Pure OOP interface (no VAR_INPUT / VAR_OUTPUT, no body call). Users declare
one FB_Span per logical operation and drive it through method calls. The FB
owns the span lifetime, enforces begin/end pairing, and provides FB_exit
safety net for abnormal teardown (online change, program stop, FB deletion).

All methods delegate to PRG_TaskLog.Span (the low-level FB_Log4TcTaskTracer
instance for the current task).

Documented in docs/traces-design.md Section "User-facing API: FB_Span".
*)
FUNCTION_BLOCK FB_Span
VAR
    _hSpan   : USINT;
    _bOpen   : BOOL;
    _eStatus : E_SpanStatus := E_SpanStatus.Ok;
    _sMsg    : STRING(80);
END_VAR
(*
Body empty — all work happens in methods that delegate to PRG_TaskLog.Span.
*)
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="Begin" Id="{f8a9b0c1-d2e3-44x5-y6z7-a8b9c0d1e2f3}">
      <Declaration><![CDATA[METHOD PUBLIC Begin : BOOL
VAR_INPUT
    sName : STRING(60);
    eKind : E_SpanKind := E_SpanKind.Internal;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* If already open, close the old span with error before starting the new one *)
IF _bOpen THEN
    _eStatus := E_SpanStatus.Error;
    _sMsg := 'span.begin called twice without end';
    End();
END_IF;

(* Begin a new span on the task tracer *)
_hSpan := PRG_TaskLog.Span.Begin(sName, eKind, '');

(* Mark open and reset status *)
_bOpen := TRUE;
_eStatus := E_SpanStatus.Ok;
_sMsg := '';

Begin := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="End" Id="{a9b0c1d2-e3f4-45y6-z7a8-b9c0d1e2f3g4}">
      <Declaration><![CDATA[METHOD PUBLIC End : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

(* If status is Error, pass the error message to the tracer *)
IF _eStatus = E_SpanStatus.Error THEN
    PRG_TaskLog.Span.SetError(_hSpan, _sMsg);
END_IF;

(* End the span *)
PRG_TaskLog.Span.End(_hSpan);

(* Clear state *)
_bOpen := FALSE;
_hSpan := 0;
_eStatus := E_SpanStatus.Ok;
_sMsg := '';

End := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddInt" Id="{b0c1d2e3-f4a5-46z7-a8b9-c0d1e2f3g4h5}">
      <Declaration><![CDATA[METHOD PUBLIC AddInt : BOOL
VAR_INPUT
    sKey : STRING(30);
    nVal : DINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddInt := PRG_TaskLog.Span.AddInt(_hSpan, sKey, nVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddLInt" Id="{c1d2e3f4-a5b6-47a8-b9c0-d1e2f3g4h5i6}">
      <Declaration><![CDATA[METHOD PUBLIC AddLInt : BOOL
VAR_INPUT
    sKey : STRING(30);
    nVal : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddLInt := PRG_TaskLog.Span.AddLInt(_hSpan, sKey, nVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddReal" Id="{d2e3f4a5-b6c7-48b9-c0d1-e2f3g4h5i6j7}">
      <Declaration><![CDATA[METHOD PUBLIC AddReal : BOOL
VAR_INPUT
    sKey : STRING(30);
    fVal : LREAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddReal := PRG_TaskLog.Span.AddReal(_hSpan, sKey, fVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddBool" Id="{e3f4a5b6-c7d8-49c0-d1e2-f3g4h5i6j7k8}">
      <Declaration><![CDATA[METHOD PUBLIC AddBool : BOOL
VAR_INPUT
    sKey : STRING(30);
    bVal : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddBool := PRG_TaskLog.Span.AddBool(_hSpan, sKey, bVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddString" Id="{f4a5b6c7-d8e9-40d1-e2f3-g4h5i6j7k8l9}">
      <Declaration><![CDATA[METHOD PUBLIC AddString : BOOL
VAR_INPUT
    sKey : STRING(30);
    sVal : STRING(120);
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddString := PRG_TaskLog.Span.AddString(_hSpan, sKey, sVal);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddEvent" Id="{a5b6c7d8-e9f0-41e2-f3g4-h5i6j7k8l9m0}">
      <Declaration><![CDATA[METHOD PUBLIC AddEvent : BOOL
VAR_INPUT
    sName : STRING(30);
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

AddEvent := PRG_TaskLog.Span.AddEvent(_hSpan, sName);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="MarkError" Id="{b6c7d8e9-f0a1-42f3-g4h5-i6j7k8l9m0n1}">
      <Declaration><![CDATA[METHOD PUBLIC MarkError : BOOL
VAR_INPUT
    sMsg : STRING(80);
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT _bOpen THEN
    RETURN;
END_IF;

_eStatus := E_SpanStatus.Error;
_sMsg := sMsg;

MarkError := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Property Name="IsOpen" Id="{c7d8e9f0-a1b2-43g4-h5i6-j7k8l9m0n1o2}">
      <Declaration><![CDATA[PROPERTY PUBLIC IsOpen : BOOL]]></Declaration>
      <Get Name="Get" Id="{d8e9f0a1-b2c3-44h5-i6j7-k8l9m0n1o2p3}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[IsOpen := _bOpen;
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="Handle" Id="{e9f0a1b2-c3d4-45i6-j7k8-l9m0n1o2p3q4}">
      <Declaration><![CDATA[PROPERTY PUBLIC Handle : USINT]]></Declaration>
      <Get Name="Get" Id="{f0a1b2c3-d4e5-46j7-k8l9-m0n1o2p3q4r5}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[Handle := _hSpan;
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="Status" Id="{a1b2c3d4-e5f6-47k8-l9m0-n1o2p3q4r5s6}">
      <Declaration><![CDATA[PROPERTY PUBLIC Status : E_SpanStatus]]></Declaration>
      <Get Name="Get" Id="{b2c3d4e5-f6a7-48l9-m0n1-o2p3q4r5s6t7}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[Status := _eStatus;
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="FB_exit" Id="{c3d4e5f6-a7b8-49m0-n1o2-p3q4r5s6t7u8}">
      <Declaration><![CDATA[METHOD FB_exit : BOOL
VAR_INPUT
    bInCopyCode : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* If the span is still open and we're not in copy code (i.e., the FB is
   being destroyed), close it with an error so tc-otel doesn't wait out
   the TTL. *)
IF _bOpen AND NOT bInCopyCode THEN
    _eStatus := E_SpanStatus.Error;
    _sMsg := 'FB_Span instance destroyed while open';
    End();
END_IF;

FB_exit := TRUE;
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>