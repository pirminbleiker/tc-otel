<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_Log4TcTaskTracer" Id="{d4e5f6a7-b8c9-40j1-k2l3-m4n5o6p7q8r9}" SpecialFunc="None">
    <Declaration><![CDATA[(*
:Description: Per-task low-level OpenTelemetry trace emitter.

One instance per task lives in PRG_TaskLog.aTaskTracer. Each method emits
exactly one wire event into the existing ADS write buffer (same path the
logger uses). Wire events are demuxed by tc-otel into a SpanEventDispatcher.

Wire format documented in docs/traces-design.md Section "Wire Format".
*)
{attribute 'no_explicit_call' := 'no direct call necessary'}
{attribute 'conditionalshow'}
FUNCTION_BLOCK FB_Log4TcTaskTracer
VAR
    (* Slot allocation and parent tracking *)
    aSlots           : ARRAY[0..15] OF ST_SpanSlot;
    nNextLocalId     : USINT := 0;

    (* Implicit parent stack for nested spans *)
    aStack           : ARRAY[0..15] OF USINT;
    nStackDepth      : USINT := 0;

    (* Wire format constants *)
    nEventTypeBegin  : BYTE := 5;
    nEventTypeAttr   : BYTE := 6;
    nEventTypeEvent  : BYTE := 7;
    nEventTypeEnd    : BYTE := 8;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="Call" Id="{e5f6a7b8-c9d0-41k2-l3m4-n5o6p7q8r9s0}">
      <Declaration><![CDATA[METHOD PUBLIC Call
(* No-op in Phase-1: wire events flushed on emission. *)
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="Begin" Id="{f6a7b8c9-d0e1-42l3-m4n5-o6p7q8r9s0t1}">
      <Declaration><![CDATA[METHOD PUBLIC Begin : USINT
VAR_INPUT
    sName        : STRING(60);
    eKind        : E_SpanKind := E_SpanKind.Internal;
    sTraceParent : STRING(60) := '';
END_VAR
VAR
    hSpan          : USINT;
    nTaskIndex     : USINT;
    nNameLen       : USINT;
    nTpLen         : USINT;
    nFlagsBegin    : BYTE;
    nTotalLen      : UDINT;
    nDcTime        : LINT;
    pBuffer        : POINTER TO FB_LogBuffer;
    pWrite         : PVOID;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Allocate next slot *)
hSpan := nNextLocalId;
IF hSpan > 254 THEN
    RETURN;  (* Guard against 0xFF reserved value *)
END_IF

(* Mark slot as in-use and record parent *)
aSlots[hSpan].bInUse := TRUE;
IF nStackDepth > 0 THEN
    aSlots[hSpan].parent_local_id := aStack[nStackDepth - 1];
ELSE
    aSlots[hSpan].parent_local_id := 16#FF;
END_IF

(* Push onto stack *)
IF nStackDepth < 16 THEN
    aStack[nStackDepth] := hSpan;
    nStackDepth := nStackDepth + 1;
END_IF

(* Prepare flags *)
nFlagsBegin := 0;
IF aSlots[hSpan].parent_local_id = 16#FF THEN
    nFlagsBegin := nFlagsBegin OR 1;  (* flag_is_root *)
END_IF;
IF Tc2_Utilities.LEN2(ADR(sTraceParent)) > 0 THEN
    nFlagsBegin := nFlagsBegin OR 2;  (* flag_has_external_parent *)
END_IF;

(* Get current time and task index *)
nDcTime := Tc2_EtherCAT.F_GetActualDcTime64();
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIndex := Tc2_Utilities.GETCURTASKINDEXEX();

(* Prepare frame sizes *)
nNameLen := Tc2_Utilities.LEN2(ADR(sName));
IF nNameLen > 127 THEN
    nNameLen := 127;
END_IF;

nTpLen := 0;
IF nFlagsBegin AND 2 <> 0 THEN
    nTpLen := Tc2_Utilities.LEN2(ADR(sTraceParent));
    IF nTpLen > 127 THEN
        nTpLen := 127;
    END_IF;
END_IF;

(* Total frame size: header(12) + parent(1) + kind(1) + name_len(1) + reserved(1) + name + [tp_len + tp] *)
nTotalLen := 12 + 4 + nNameLen;
IF nFlagsBegin AND 2 <> 0 THEN
    nTotalLen := nTotalLen + 1 + nTpLen;
END_IF;

(* Write frame *)
pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 THEN
    pWrite := pBuffer^.BufferPtr + pBuffer^.BufferCount;

    (* Header *)
    MEMCPY(pWrite + 0, ADR(nEventTypeBegin), 1);
    MEMCPY(pWrite + 1, ADR(hSpan), 1);
    MEMCPY(pWrite + 2, ADR(nTaskIndex), 1);
    MEMCPY(pWrite + 3, ADR(nFlagsBegin), 1);
    MEMCPY(pWrite + 4, ADR(nDcTime), 8);

    (* Payload *)
    MEMCPY(pWrite + 12, ADR(aSlots[hSpan].parent_local_id), 1);
    MEMCPY(pWrite + 13, ADR(eKind), 1);
    MEMCPY(pWrite + 14, ADR(nNameLen), 1);

    IF nNameLen > 0 THEN
        MEMCPY(pWrite + 16, ADR(sName), nNameLen);
    END_IF;

    IF nFlagsBegin AND 2 <> 0 THEN
        MEMCPY(pWrite + 16 + nNameLen, ADR(nTpLen), 1);
        IF nTpLen > 0 THEN
            MEMCPY(pWrite + 17 + nNameLen, ADR(sTraceParent), nTpLen);
        END_IF;
    END_IF;

    pBuffer^.BufferCount := pBuffer^.BufferCount + nTotalLen;
END_IF;

(* Increment for next allocation *)
nNextLocalId := nNextLocalId + 1;

Begin := hSpan;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddInt" Id="{a7b8c9d0-e1f2-43m4-n5o6-p7q8r9s0t1u2}">
      <Declaration><![CDATA[METHOD PUBLIC AddInt : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    nVal  : DINT;
END_VAR
VAR
    nKeyLen    : USINT;
    nDcTime    : LINT;
    nTaskIdx   : USINT;
    nValueType : BYTE := 1;
    pBuffer    : POINTER TO FB_LogBuffer;
    pWrite     : PVOID;
    nTotalLen  : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;

nDcTime := Tc2_EtherCAT.F_GetActualDcTime64();
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := Tc2_Utilities.GETCURTASKINDEXEX();

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(8) *)
nTotalLen := 12 + 4 + nKeyLen + 8;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 THEN
    pWrite := pBuffer^.BufferPtr + pBuffer^.BufferCount;

    (* Header *)
    _WriteFrameHeader(pWrite, nEventTypeAttr, hSpan, nTaskIdx, nDcTime);

    (* Payload *)
    MEMCPY(pWrite + 12, ADR(nValueType), 1);
    MEMCPY(pWrite + 13, ADR(nKeyLen), 1);

    IF nKeyLen > 0 THEN
        MEMCPY(pWrite + 16, ADR(sKey), nKeyLen);
    END_IF;

    MEMCPY(pWrite + 16 + nKeyLen, ADR(nVal), 8);

    pBuffer^.BufferCount := pBuffer^.BufferCount + nTotalLen;
END_IF;

AddInt := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddLInt" Id="{b8c9d0e1-f2a3-44n5-o6p7-q8r9s0t1u2v3}">
      <Declaration><![CDATA[METHOD PUBLIC AddLInt : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    nVal  : LINT;
END_VAR
VAR
    nKeyLen    : USINT;
    nDcTime    : LINT;
    nTaskIdx   : USINT;
    nValueType : BYTE := 1;
    pBuffer    : POINTER TO FB_LogBuffer;
    pWrite     : PVOID;
    nTotalLen  : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;

nDcTime := Tc2_EtherCAT.F_GetActualDcTime64();
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := Tc2_Utilities.GETCURTASKINDEXEX();

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(8) *)
nTotalLen := 12 + 4 + nKeyLen + 8;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 THEN
    pWrite := pBuffer^.BufferPtr + pBuffer^.BufferCount;

    (* Header *)
    _WriteFrameHeader(pWrite, nEventTypeAttr, hSpan, nTaskIdx, nDcTime);

    (* Payload *)
    MEMCPY(pWrite + 12, ADR(nValueType), 1);
    MEMCPY(pWrite + 13, ADR(nKeyLen), 1);

    IF nKeyLen > 0 THEN
        MEMCPY(pWrite + 16, ADR(sKey), nKeyLen);
    END_IF;

    MEMCPY(pWrite + 16 + nKeyLen, ADR(nVal), 8);

    pBuffer^.BufferCount := pBuffer^.BufferCount + nTotalLen;
END_IF;

AddLInt := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddReal" Id="{c9d0e1f2-a3b4-45o6-p7q8-r9s0t1u2v3w4}">
      <Declaration><![CDATA[METHOD PUBLIC AddReal : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    fVal  : LREAL;
END_VAR
VAR
    nKeyLen    : USINT;
    nDcTime    : LINT;
    nTaskIdx   : USINT;
    nValueType : BYTE := 2;
    pBuffer    : POINTER TO FB_LogBuffer;
    pWrite     : PVOID;
    nTotalLen  : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;

nDcTime := Tc2_EtherCAT.F_GetActualDcTime64();
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := Tc2_Utilities.GETCURTASKINDEXEX();

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(8) *)
nTotalLen := 12 + 4 + nKeyLen + 8;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 THEN
    pWrite := pBuffer^.BufferPtr + pBuffer^.BufferCount;

    (* Header *)
    _WriteFrameHeader(pWrite, nEventTypeAttr, hSpan, nTaskIdx, nDcTime);

    (* Payload *)
    MEMCPY(pWrite + 12, ADR(nValueType), 1);
    MEMCPY(pWrite + 13, ADR(nKeyLen), 1);

    IF nKeyLen > 0 THEN
        MEMCPY(pWrite + 16, ADR(sKey), nKeyLen);
    END_IF;

    MEMCPY(pWrite + 16 + nKeyLen, ADR(fVal), 8);

    pBuffer^.BufferCount := pBuffer^.BufferCount + nTotalLen;
END_IF;

AddReal := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddBool" Id="{d0e1f2a3-b4c5-46p7-q8r9-s0t1u2v3w4x5}">
      <Declaration><![CDATA[METHOD PUBLIC AddBool : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    bVal  : BOOL;
END_VAR
VAR
    nKeyLen    : USINT;
    nDcTime    : LINT;
    nTaskIdx   : USINT;
    nValueType : BYTE := 3;
    pBuffer    : POINTER TO FB_LogBuffer;
    pWrite     : PVOID;
    nTotalLen  : UDINT;
    byVal      : BYTE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;

nDcTime := Tc2_EtherCAT.F_GetActualDcTime64();
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := Tc2_Utilities.GETCURTASKINDEXEX();

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(1) *)
nTotalLen := 12 + 4 + nKeyLen + 1;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 THEN
    pWrite := pBuffer^.BufferPtr + pBuffer^.BufferCount;

    (* Header *)
    _WriteFrameHeader(pWrite, nEventTypeAttr, hSpan, nTaskIdx, nDcTime);

    (* Payload *)
    MEMCPY(pWrite + 12, ADR(nValueType), 1);
    MEMCPY(pWrite + 13, ADR(nKeyLen), 1);

    IF nKeyLen > 0 THEN
        MEMCPY(pWrite + 16, ADR(sKey), nKeyLen);
    END_IF;

    byVal := BOOL_TO_BYTE(bVal);
    MEMCPY(pWrite + 16 + nKeyLen, ADR(byVal), 1);

    pBuffer^.BufferCount := pBuffer^.BufferCount + nTotalLen;
END_IF;

AddBool := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddString" Id="{e1f2a3b4-c5d6-47q8-r9s0-t1u2v3w4x5y6}">
      <Declaration><![CDATA[METHOD PUBLIC AddString : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    sVal  : STRING(120);
END_VAR
VAR
    nKeyLen    : USINT;
    nValLen    : USINT;
    nDcTime    : LINT;
    nTaskIdx   : USINT;
    nValueType : BYTE := 4;
    pBuffer    : POINTER TO FB_LogBuffer;
    pWrite     : PVOID;
    nTotalLen  : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;

nValLen := Tc2_Utilities.LEN2(ADR(sVal));
IF nValLen > 127 THEN
    nValLen := 127;
END_IF;

nDcTime := Tc2_EtherCAT.F_GetActualDcTime64();
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := Tc2_Utilities.GETCURTASKINDEXEX();

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value *)
nTotalLen := 12 + 4 + nKeyLen + nValLen;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 THEN
    pWrite := pBuffer^.BufferPtr + pBuffer^.BufferCount;

    (* Header *)
    _WriteFrameHeader(pWrite, nEventTypeAttr, hSpan, nTaskIdx, nDcTime);

    (* Payload *)
    MEMCPY(pWrite + 12, ADR(nValueType), 1);
    MEMCPY(pWrite + 13, ADR(nKeyLen), 1);
    MEMCPY(pWrite + 14, ADR(nValLen), 1);

    IF nKeyLen > 0 THEN
        MEMCPY(pWrite + 16, ADR(sKey), nKeyLen);
    END_IF;

    IF nValLen > 0 THEN
        MEMCPY(pWrite + 16 + nKeyLen, ADR(sVal), nValLen);
    END_IF;

    pBuffer^.BufferCount := pBuffer^.BufferCount + nTotalLen;
END_IF;

AddString := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddEvent" Id="{f2a3b4c5-d6e7-48r9-s0t1-u2v3w4x5y6z7}">
      <Declaration><![CDATA[METHOD PUBLIC AddEvent : BOOL
VAR_INPUT
    hSpan : USINT;
    sName : STRING(30);
END_VAR
VAR
    nNameLen   : USINT;
    nDcTime    : LINT;
    nTaskIdx   : USINT;
    nAttrCount : BYTE := 0;
    pBuffer    : POINTER TO FB_LogBuffer;
    pWrite     : PVOID;
    nTotalLen  : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nNameLen := Tc2_Utilities.LEN2(ADR(sName));
IF nNameLen > 31 THEN
    nNameLen := 31;
END_IF;

nDcTime := Tc2_EtherCAT.F_GetActualDcTime64();
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := Tc2_Utilities.GETCURTASKINDEXEX();

(* Frame: header(12) + name_len(1) + attr_count(1) + reserved(2) + name *)
nTotalLen := 12 + 4 + nNameLen;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 THEN
    pWrite := pBuffer^.BufferPtr + pBuffer^.BufferCount;

    (* Header *)
    _WriteFrameHeader(pWrite, nEventTypeEvent, hSpan, nTaskIdx, nDcTime);

    (* Payload *)
    MEMCPY(pWrite + 12, ADR(nNameLen), 1);
    MEMCPY(pWrite + 13, ADR(nAttrCount), 1);

    IF nNameLen > 0 THEN
        MEMCPY(pWrite + 16, ADR(sName), nNameLen);
    END_IF;

    pBuffer^.BufferCount := pBuffer^.BufferCount + nTotalLen;
END_IF;

AddEvent := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetError" Id="{a3b4c5d6-e7f8-49s0-t1u2-v3w4x5y6z7a8}">
      <Declaration><![CDATA[METHOD PUBLIC SetError : BOOL
VAR_INPUT
    hSpan : USINT;
    sMsg  : STRING(120) := '';
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

(* Phase-1: Store error state. FB_Span will pass error status to End(). *)
SetError := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="End" Id="{b4c5d6e7-f8a9-40t1-u2v3-w4x5y6z7a8b9}">
      <Declaration><![CDATA[METHOD PUBLIC End : BOOL
VAR_INPUT
    hSpan : USINT;
END_VAR
VAR
    nTaskIdx   : USINT;
    nDcTime    : LINT;
    nStatus    : BYTE := 1;
    nMsgLen    : USINT := 0;
    pBuffer    : POINTER TO FB_LogBuffer;
    pWrite     : PVOID;
    nTotalLen  : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nDcTime := Tc2_EtherCAT.F_GetActualDcTime64();
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := Tc2_Utilities.GETCURTASKINDEXEX();

(* Frame: header(12) + status(1) + msg_len(1) + reserved(2) + msg *)
nTotalLen := 12 + 4 + nMsgLen;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 THEN
    pWrite := pBuffer^.BufferPtr + pBuffer^.BufferCount;

    (* Header *)
    _WriteFrameHeader(pWrite, nEventTypeEnd, hSpan, nTaskIdx, nDcTime);

    (* Payload *)
    MEMCPY(pWrite + 12, ADR(nStatus), 1);
    MEMCPY(pWrite + 13, ADR(nMsgLen), 1);

    pBuffer^.BufferCount := pBuffer^.BufferCount + nTotalLen;
END_IF;

(* Pop from stack if on top *)
IF nStackDepth > 0 AND aStack[nStackDepth - 1] = hSpan THEN
    nStackDepth := nStackDepth - 1;
END_IF;

(* Free the slot *)
aSlots[hSpan].bInUse := FALSE;

End := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="CurrentTraceParent" Id="{c5d6e7f8-a9b0-41u2-v3w4-x5y6z7a8b9c0}">
      <Declaration><![CDATA[METHOD PUBLIC CurrentTraceParent : STRING(60)
VAR
    sResult : STRING(60) := '';
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Phase-1: Return empty string with TODO comment.
   Rust side mints trace_id and span_id; PLC side doesn't have them.
   Phase-5 (cross-PLC propagation) will implement this.
   For now, callers pass traceparent explicitly via Begin(). *)

CurrentTraceParent := sResult;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_WriteFrameHeader" Id="{d6e7f8a9-b0c1-42v3-w4x5-y6z7a8b9c0d1}">
      <Declaration><![CDATA[METHOD PRIVATE _WriteFrameHeader
VAR_INPUT
    pWrite     : PVOID;
    nEventType : BYTE;
    hSpan      : USINT;
    nTaskIdx   : USINT;
    nDcTime    : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
MEMCPY(pWrite + 0, ADR(nEventType), 1);
MEMCPY(pWrite + 1, ADR(hSpan), 1);
MEMCPY(pWrite + 2, ADR(nTaskIdx), 1);
MEMCPY(pWrite + 4, ADR(nDcTime), 8);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_GetTaskDcTime" Id="{e7f8a9b0-c1d2-43w4-x5y6-z7a8b9c0d1e2}">
      <Declaration><![CDATA[METHOD PRIVATE _GetTaskDcTime : LINT
VAR
    nTaskIdx : USINT;
    pTaskInfo : POINTER TO PlcTaskSystemInfo;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
nTaskIdx := Tc2_Utilities.GETCURTASKINDEXEX();
IF nTaskIdx > 0 AND nTaskIdx <= SIZEOF(TwinCAT_SystemInfoVarList._TaskInfo) / SIZEOF(PlcTaskSystemInfo) THEN
    pTaskInfo := ADR(TwinCAT_SystemInfoVarList._TaskInfo[nTaskIdx]);
    _GetTaskDcTime := pTaskInfo^.DcTaskTime;
ELSE
    _GetTaskDcTime := 0;
END_IF;
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>