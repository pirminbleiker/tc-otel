END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(8) *)
nTotalLen := 12 + 4 + nKeyLen + 8;

