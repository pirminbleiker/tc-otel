<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_Log4TcTaskTracer" Id="{294f80cd-71bb-4a49-ab79-358e75196d66}" SpecialFunc="None">
    <Declaration><![CDATA[(*
:Description: Per-task low-level OpenTelemetry trace emitter.

One instance per task lives in PRG_TaskLog.aTaskTracer. Each method emits
exactly one wire event into the existing ADS write buffer (same path the
logger uses). Wire events are demuxed by tc-otel into a SpanEventDispatcher.

Wire format documented in docs/traces-design.md Section "Wire Format".
*)
{attribute 'no_explicit_call' := 'no direct call necessary'}
{attribute 'conditionalshow'}
FUNCTION_BLOCK FB_Log4TcTaskTracer
VAR
    (* Slot allocation and parent tracking. hSpan is USINT (0..254) per the
       wire format; 0xFF is reserved for 'no parent'. *)
    aSlots           : ARRAY[0..254] OF ST_SpanSlot;
    nNextLocalId     : USINT := 0;

    (* Implicit parent stack for nested spans. 16 levels is plenty in practice. *)
    aStack           : ARRAY[0..15] OF USINT;
    nStackDepth      : USINT := 0;

    (* Wire format constants *)
    nEventTypeBegin  : BYTE := 5;
    nEventTypeAttr   : BYTE := 6;
    nEventTypeEvent  : BYTE := 7;
    nEventTypeEnd    : BYTE := 8;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="_GetTaskDcTime" Id="{9b32520a-c9fc-420a-8034-c0663bb4b6b9}">
      <Declaration><![CDATA[METHOD PRIVATE _GetTaskDcTime : LINT
VAR
    nTaskIdx : DINT;
    pTaskInfo : POINTER TO PlcTaskSystemInfo;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
nTaskIdx := Tc2_Utilities.GETCURTASKINDEXEX();
IF nTaskIdx > 0 AND nTaskIdx <= SIZEOF(TwinCAT_SystemInfoVarList._TaskInfo) / SIZEOF(PlcTaskSystemInfo) THEN
    pTaskInfo := ADR(TwinCAT_SystemInfoVarList._TaskInfo[nTaskIdx]);
    _GetTaskDcTime := pTaskInfo^.DcTaskTime;
ELSE
    _GetTaskDcTime := 0;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_WriteFrameHeader" Id="{5c95a435-e5f4-4be0-a30e-3e2cecf13cfe}">
      <Declaration><![CDATA[METHOD PRIVATE _WriteFrameHeader
VAR_INPUT
    pWriteBuffer : POINTER TO FB_LogBuffer;
    nEventType   : BYTE;
    hSpan        : USINT;
    nTaskIdx     : USINT;
    nFlags       : BYTE;
    nDcTime      : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pWriteBuffer^.BufferFree >= 12 THEN
    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nEventType), 1);
    pWriteBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(hSpan), 1);
    pWriteBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nTaskIdx), 1);
    pWriteBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nFlags), 1);
    pWriteBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nDcTime), 8);
    pWriteBuffer^.DataAdded(8);
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddBool" Id="{f026cfda-ccb5-4225-9dac-a2799fe5b6bd}">
      <Declaration><![CDATA[METHOD PUBLIC AddBool : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    bVal  : BOOL;
END_VAR
VAR
    nKeyLen    : UDINT;
    nKeyLenUsint : USINT;
    nDcTime    : LINT;
    nTaskIdx   : USINT;
    nValueType : BYTE := 3;
    pBuffer    : POINTER TO FB_LogBuffer;
    nTotalLen  : UDINT;
    byVal      : BYTE;
    nFlags     : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(1) *)
nTotalLen := 12 + 4 + nKeyLen + 1;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeAttr, hSpan, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* value_len for bool *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    byVal := BOOL_TO_BYTE(bVal);
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(byVal), 1);
    pBuffer^.DataAdded(1);

    AddBool := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddEvent" Id="{731c0681-f28c-468d-9a22-08d93456bc4b}">
      <Declaration><![CDATA[METHOD PUBLIC AddEvent : BOOL
VAR_INPUT
    hSpan : USINT;
    sName : STRING(30);
END_VAR
VAR
    nNameLen    : UDINT;
    nNameLenUsint : USINT;
    nDcTime     : LINT;
    nTaskIdx    : USINT;
    nAttrCount  : BYTE := 0;
    pBuffer     : POINTER TO FB_LogBuffer;
    nTotalLen   : UDINT;
    nFlags      : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nNameLen := Tc2_Utilities.LEN2(ADR(sName));
IF nNameLen > 31 THEN
    nNameLen := 31;
END_IF;
nNameLenUsint := TO_USINT(nNameLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(12) + name_len(1) + attr_count(1) + reserved(2) + name *)
nTotalLen := 12 + 4 + nNameLen;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeEvent, hSpan, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nNameLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nAttrCount), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nAttrCount), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nAttrCount), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nNameLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sName), nNameLen);
        pBuffer^.DataAdded(nNameLen);
    END_IF;

    AddEvent := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddInt" Id="{cebf7902-798a-47a4-b3e5-37d8ad80e0e0}">
      <Declaration><![CDATA[METHOD PUBLIC AddInt : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    nVal  : DINT;
END_VAR
VAR
    nKeyLen     : UDINT;
    nKeyLenUsint : USINT;
    nDcTime     : LINT;
    nTaskIdx    : USINT;
    nValueType  : BYTE := 1;
    pBuffer     : POINTER TO FB_LogBuffer;
    nTotalLen   : UDINT;
    nFlags      : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(8) *)
nTotalLen := 12 + 4 + nKeyLen + 8;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeAttr, hSpan, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* value_len *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nVal), 8);
    pBuffer^.DataAdded(8);

    AddInt := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddLInt" Id="{40a748f6-c411-43f0-994d-38e870c92549}">
      <Declaration><![CDATA[METHOD PUBLIC AddLInt : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    nVal  : LINT;
END_VAR
VAR
    nKeyLen     : UDINT;
    nKeyLenUsint : USINT;
    nDcTime     : LINT;
    nTaskIdx    : USINT;
    nValueType  : BYTE := 1;
    pBuffer     : POINTER TO FB_LogBuffer;
    nTotalLen   : UDINT;
    nFlags      : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
