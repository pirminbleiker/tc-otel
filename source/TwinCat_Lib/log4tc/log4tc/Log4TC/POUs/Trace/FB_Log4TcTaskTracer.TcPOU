END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddReal" Id="{6a9dc70f-5325-45d1-8be5-172af842881e}">
      <Declaration><![CDATA[METHOD PUBLIC AddReal : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    fVal  : LREAL;
END_VAR
VAR
    nKeyLen     : UDINT;
    nKeyLenUsint : USINT;
    nDcTime     : LINT;
    nTaskIdx    : USINT;
    nValueType  : BYTE := 2;
    pBuffer     : POINTER TO FB_LogBuffer;
    nTotalLen   : UDINT;
    nFlags      : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(8) *)
nTotalLen := 12 + 4 + nKeyLen + 8;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeAttr, hSpan, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* value_len *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(fVal), 8);
    pBuffer^.DataAdded(8);

    AddReal := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddString" Id="{59a3fb41-a2f5-4bd0-ad49-dd002f212acc}">
      <Declaration><![CDATA[METHOD PUBLIC AddString : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    sVal  : STRING(120);
END_VAR
VAR
    nKeyLen      : UDINT;
    nKeyLenUsint : USINT;
    nValLen      : UDINT;
    nValLenUsint : USINT;
    nDcTime      : LINT;
    nTaskIdx     : USINT;
    nValueType   : BYTE := 4;
    pBuffer      : POINTER TO FB_LogBuffer;
    nTotalLen    : UDINT;
    nFlags       : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nValLen := Tc2_Utilities.LEN2(ADR(sVal));
IF nValLen > 127 THEN
    nValLen := 127;
END_IF;
nValLenUsint := TO_USINT(nValLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value *)
nTotalLen := 12 + 4 + nKeyLen + nValLen;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeAttr, hSpan, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    IF nValLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sVal), nValLen);
        pBuffer^.DataAdded(nValLen);
    END_IF;

    AddString := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Begin" Id="{832e89db-497a-4d07-b3b1-c6e95e2f7e46}">
      <Declaration><![CDATA[METHOD PUBLIC Begin : USINT
VAR_INPUT
    sName        : STRING(60);
    eKind        : E_SpanKind := E_SpanKind.eInternal;
    sTraceParent : STRING(60) := '';
END_VAR
VAR
    hSpan           : USINT;
    nTaskIndex      : USINT;
    nNameLen        : UDINT;
    nNameLenUsint   : USINT;
    nTpLen          : UDINT;
    nTpLenUsint     : USINT;
    nFlagsBegin     : BYTE;
    nTotalLen       : UDINT;
    nDcTime         : LINT;
    pBuffer         : POINTER TO FB_LogBuffer;
    eKindByte       : BYTE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Allocate next slot *)
hSpan := nNextLocalId;
IF hSpan > 254 THEN
    RETURN;  (* Guard against 0xFF reserved value *)
END_IF

(* Mark slot as in-use and record parent *)
aSlots[hSpan].bInUse := TRUE;
IF nStackDepth > 0 THEN
    aSlots[hSpan].parent_local_id := aStack[nStackDepth - 1];
ELSE
    aSlots[hSpan].parent_local_id := 16#FF;
END_IF

(* Push onto stack *)
IF nStackDepth < 16 THEN
    aStack[nStackDepth] := hSpan;
    nStackDepth := nStackDepth + 1;
END_IF

(* Prepare flags *)
nFlagsBegin := 0;
IF aSlots[hSpan].parent_local_id = 16#FF THEN
    nFlagsBegin := nFlagsBegin OR 1;  (* flag_is_root *)
END_IF;
IF Tc2_Utilities.LEN2(ADR(sTraceParent)) > 0 THEN
    nFlagsBegin := nFlagsBegin OR 2;  (* flag_has_external_parent *)
END_IF;

(* Get current time and task index *)
nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIndex := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Prepare frame sizes *)
nNameLen := Tc2_Utilities.LEN2(ADR(sName));
IF nNameLen > 127 THEN
    nNameLen := 127;
END_IF;
nNameLenUsint := TO_USINT(nNameLen);

nTpLen := 0;
nTpLenUsint := 0;
IF (nFlagsBegin AND 2) <> 0 THEN
    nTpLen := Tc2_Utilities.LEN2(ADR(sTraceParent));
    IF nTpLen > 127 THEN
        nTpLen := 127;
    END_IF;
    nTpLenUsint := TO_USINT(nTpLen);
END_IF;

(* Total frame size: header(12) + parent(1) + kind(1) + name_len(1) + reserved(1) + name + [tp_len + tp] *)
nTotalLen := 12 + 4 + nNameLen;
IF (nFlagsBegin AND 2) <> 0 THEN
    nTotalLen := nTotalLen + 1 + nTpLen;
END_IF;

(* Write frame *)
pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeBegin, hSpan, nTaskIndex, nFlagsBegin, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(aSlots[hSpan].parent_local_id), 1);
    pBuffer^.DataAdded(1);

    eKindByte := TO_BYTE(eKind);
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(eKindByte), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nNameLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nEventTypeBegin), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nNameLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sName), nNameLen);
        pBuffer^.DataAdded(nNameLen);
    END_IF;

    IF (nFlagsBegin AND 2) <> 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nTpLenUsint), 1);
        pBuffer^.DataAdded(1);

        IF nTpLen > 0 THEN
            Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sTraceParent), nTpLen);
            pBuffer^.DataAdded(nTpLen);
        END_IF;
    END_IF;
END_IF;

(* Increment for next allocation; wrap at 254 because 0xFF is reserved. *)
IF nNextLocalId >= 254 THEN
    nNextLocalId := 0;
ELSE
    nNextLocalId := nNextLocalId + 1;
END_IF;

Begin := hSpan;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Call" Id="{b918082d-1f06-4f72-b609-d97e60f0a088}">
      <Declaration><![CDATA[METHOD PUBLIC Call
(* No-op in Phase-1: wire events flushed on emission. *)
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="CurrentTraceParent" Id="{703b7f93-e680-4a9f-a268-bebc44b81a3d}">
      <Declaration><![CDATA[METHOD PUBLIC CurrentTraceParent : STRING(60)
VAR
    sResult : STRING(60) := '';
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Phase-1: Return empty string with TODO comment.
   Rust side mints trace_id and span_id; PLC side doesn't have them.
   Phase-5 (cross-PLC propagation) will implement this.
   For now, callers pass traceparent explicitly via Begin(). *)

CurrentTraceParent := sResult;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="End" Id="{82740a99-7e02-4458-aaa7-fef1872d30eb}">
      <Declaration><![CDATA[METHOD PUBLIC End : BOOL
VAR_INPUT
    hSpan : USINT;
END_VAR
VAR
    nTaskIdx   : USINT;
    nDcTime    : LINT;
    nStatus    : BYTE := 1;
    nMsgLen    : USINT := 0;
    pBuffer    : POINTER TO FB_LogBuffer;
    nTotalLen  : UDINT;
    nFlags     : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(12) + status(1) + msg_len(1) + reserved(2) + msg *)
nTotalLen := 12 + 4 + nMsgLen;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeEnd, hSpan, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nStatus), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nMsgLen), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nStatus), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nStatus), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    End := TRUE;
END_IF;

(* Pop from stack if on top *)
IF nStackDepth > 0 AND aStack[nStackDepth - 1] = hSpan THEN
    nStackDepth := nStackDepth - 1;
END_IF;

(* Free the slot *)
aSlots[hSpan].bInUse := FALSE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetError" Id="{1323314a-5f82-499e-a923-f4a110bbfa07}">
      <Declaration><![CDATA[METHOD PUBLIC SetError : BOOL
VAR_INPUT
    hSpan : USINT;
    sMsg  : STRING(120) := '';
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

(* Phase-1: Store error state. FB_Span will pass error status to End(). *)
SetError := TRUE;
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>