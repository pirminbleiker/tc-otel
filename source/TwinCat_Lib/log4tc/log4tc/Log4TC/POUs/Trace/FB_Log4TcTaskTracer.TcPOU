<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_Log4TcTaskTracer" Id="{294f80cd-71bb-4a49-ab79-358e75196d66}" SpecialFunc="None">
    <Declaration><![CDATA[(*
:Description: Per-task low-level OpenTelemetry trace emitter.

One instance per task lives in PRG_TaskLog.aTaskTracer. Each method emits
exactly one wire event into the existing ADS write buffer (same path the
logger uses). Wire events are demuxed by tc-otel into a SpanEventDispatcher.

Wire format documented in docs/traces-design.md Section "Wire Format".
*)
{attribute 'no_explicit_call' := 'no direct call necessary'}
{attribute 'conditionalshow'}
FUNCTION_BLOCK FB_Log4TcTaskTracer
VAR
    (* Slot allocation and parent tracking. hSpan is USINT (0..254) per the
       wire format; 0xFF is reserved for 'no parent'. *)
    aSlots           : ARRAY[0..254] OF ST_SpanSlot;
    nNextLocalId     : USINT := 0;

    (* Implicit parent stack for nested spans. 16 levels is plenty in practice. *)
    aStack           : ARRAY[0..15] OF USINT;
    nStackDepth      : USINT := 0;

    (* Wire format constants *)
    nEventTypeBegin  : BYTE := 5;
    nEventTypeAttr   : BYTE := 6;
    nEventTypeEvent  : BYTE := 7;
    nEventTypeEnd    : BYTE := 8;

    (* xorshift64 PRNG state used to mint W3C trace_id / span_id locally.
       Seeded on first Begin() call from the DC clock XOR the task index so
       separate tasks do not produce the same stream. OTel spec only
       requires randomly generated IDs — xorshift is sufficient and costs
       ~6 ops per 64-bit draw. *)
    _nXorState       : ULINT := 16#DEADBEEFCAFEF00D;
    _bRngSeeded      : BOOL  := FALSE;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="_GetTaskDcTime" Id="{9b32520a-c9fc-420a-8034-c0663bb4b6b9}">
      <Declaration><![CDATA[METHOD PRIVATE _GetTaskDcTime : LINT
VAR
    nTaskIdx : DINT;
    pTaskInfo : POINTER TO PlcTaskSystemInfo;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
nTaskIdx := Tc2_Utilities.GETCURTASKINDEXEX();
IF nTaskIdx > 0 AND nTaskIdx <= SIZEOF(TwinCAT_SystemInfoVarList._TaskInfo) / SIZEOF(PlcTaskSystemInfo) THEN
    pTaskInfo := ADR(TwinCAT_SystemInfoVarList._TaskInfo[nTaskIdx]);
    _GetTaskDcTime := pTaskInfo^.DcTaskTime;
ELSE
    _GetTaskDcTime := 0;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SeedRng" Id="{1a8f2c4d-3b5e-4a6f-8d7c-9e0a1b2c3d4f}">
      <Declaration><![CDATA[METHOD PRIVATE _SeedRng
VAR
    nDcTime : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF _bRngSeeded THEN
    RETURN;
END_IF;

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;

(* XOR with task index so separate tasks can't produce the same stream
   if two of them seed within the same DC-time tick. Add the fallback
   constant so a zero DC clock still gives a non-zero seed (xorshift64
   requires non-zero state). *)
_nXorState := TO_ULINT(nDcTime) XOR (TO_ULINT(Tc2_Utilities.GETCURTASKINDEXEX()) * 16#9E3779B97F4A7C15);
IF _nXorState = 0 THEN
    _nXorState := 16#DEADBEEFCAFEF00D;
END_IF;

_bRngSeeded := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_NextRandom" Id="{2b9e3d5f-4c6a-4b7d-8e9f-0a1b2c3d4e5f}">
      <Declaration><![CDATA[(* xorshift64 (Marsaglia 2003): 6 ops, period 2^64 - 1, zero lookup tables. *)
METHOD PRIVATE _NextRandom : ULINT
VAR
    x : ULINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
x := _nXorState;
x := x XOR SHL(x, 13);
x := x XOR SHR(x, 7);
x := x XOR SHL(x, 17);
_nXorState := x;
_NextRandom := x;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_MintTraceId" Id="{3c0a4e6b-5d7c-4e8f-9a0b-1c2d3e4f5a6b}">
      <Declaration><![CDATA[(* Fills the 16-byte trace_id of the slot at index hSpan with two xorshift64 draws. *)
METHOD PRIVATE _MintTraceId
VAR_INPUT
    hSpan : USINT;
END_VAR
VAR
    hi  : ULINT;
    lo  : ULINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
hi := _NextRandom();
lo := _NextRandom();
Tc2_System.MEMCPY(ADR(aSlots[hSpan].trace_id[0]), ADR(hi), 8);
Tc2_System.MEMCPY(ADR(aSlots[hSpan].trace_id[8]), ADR(lo), 8);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_MintSpanId" Id="{4d1b5f7c-6e8d-4f9a-0b1c-2d3e4f5a6b7c}">
      <Declaration><![CDATA[(* Fills the 8-byte span_id of the slot at index hSpan with one xorshift64 draw. *)
METHOD PRIVATE _MintSpanId
VAR_INPUT
    hSpan : USINT;
END_VAR
VAR
    v : ULINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
v := _NextRandom();
Tc2_System.MEMCPY(ADR(aSlots[hSpan].span_id[0]), ADR(v), 8);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_WriteFrameHeader" Id="{5c95a435-e5f4-4be0-a30e-3e2cecf13cfe}">
      <Declaration><![CDATA[METHOD PRIVATE _WriteFrameHeader
VAR_INPUT
    pWriteBuffer : POINTER TO FB_LogBuffer;
    nEventType   : BYTE;
    hSpan        : USINT;
    nTaskIdx     : USINT;
    nFlags       : BYTE;
    nDcTime      : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF pWriteBuffer^.BufferFree >= 12 THEN
    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nEventType), 1);
    pWriteBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(hSpan), 1);
    pWriteBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nTaskIdx), 1);
    pWriteBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nFlags), 1);
    pWriteBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pWriteBuffer^.BufferPtr, ADR(nDcTime), 8);
    pWriteBuffer^.DataAdded(8);
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddBool" Id="{f026cfda-ccb5-4225-9dac-a2799fe5b6bd}">
      <Declaration><![CDATA[METHOD PUBLIC AddBool : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    bVal  : BOOL;
END_VAR
VAR
    nKeyLen    : UDINT;
    nKeyLenUsint : USINT;
    nDcTime    : LINT;
    nTaskIdx   : USINT;
    nValueType : BYTE := 3;
    pBuffer    : POINTER TO FB_LogBuffer;
    nTotalLen  : UDINT;
    byVal      : BYTE;
    nFlags     : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(1) *)
nTotalLen := 12 + 4 + nKeyLen + 1;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeAttr, hSpan, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* value_len for bool *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    byVal := BOOL_TO_BYTE(bVal);
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(byVal), 1);
    pBuffer^.DataAdded(1);

    AddBool := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddEvent" Id="{731c0681-f28c-468d-9a22-08d93456bc4b}">
      <Declaration><![CDATA[METHOD PUBLIC AddEvent : BOOL
VAR_INPUT
    hSpan : USINT;
    sName : STRING(30);
END_VAR
VAR
    nNameLen    : UDINT;
    nNameLenUsint : USINT;
    nDcTime     : LINT;
    nTaskIdx    : USINT;
    nAttrCount  : BYTE := 0;
    pBuffer     : POINTER TO FB_LogBuffer;
    nTotalLen   : UDINT;
    nFlags      : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nNameLen := Tc2_Utilities.LEN2(ADR(sName));
IF nNameLen > 31 THEN
    nNameLen := 31;
END_IF;
nNameLenUsint := TO_USINT(nNameLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(12) + name_len(1) + attr_count(1) + reserved(2) + name *)
nTotalLen := 12 + 4 + nNameLen;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeEvent, hSpan, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nNameLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nAttrCount), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nAttrCount), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nAttrCount), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nNameLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sName), nNameLen);
        pBuffer^.DataAdded(nNameLen);
    END_IF;

    AddEvent := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddInt" Id="{cebf7902-798a-47a4-b3e5-37d8ad80e0e0}">
      <Declaration><![CDATA[METHOD PUBLIC AddInt : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    nVal  : DINT;
END_VAR
VAR
    nKeyLen     : UDINT;
    nKeyLenUsint : USINT;
    nDcTime     : LINT;
    nTaskIdx    : USINT;
    nValueType  : BYTE := 1;
    pBuffer     : POINTER TO FB_LogBuffer;
    nTotalLen   : UDINT;
    nFlags      : BYTE := 0;
    nValLint    : LINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Widen DINT → LINT so the 8-byte wire field carries the full value
   instead of 4 bytes of stack garbage past the DINT. *)
nValLint := DINT_TO_LINT(nVal);

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(8) *)
nTotalLen := 12 + 4 + nKeyLen + 8;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeAttr, hSpan, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* value_len *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValLint), 8);
    pBuffer^.DataAdded(8);

    AddInt := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddLInt" Id="{40a748f6-c411-43f0-994d-38e870c92549}">
      <Declaration><![CDATA[METHOD PUBLIC AddLInt : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    nVal  : LINT;
END_VAR
VAR
    nKeyLen     : UDINT;
    nKeyLenUsint : USINT;
    nDcTime     : LINT;
    nTaskIdx    : USINT;
    nValueType  : BYTE := 1;
    pBuffer     : POINTER TO FB_LogBuffer;
    nTotalLen   : UDINT;
    nFlags      : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(8) *)
nTotalLen := 12 + 4 + nKeyLen + 8;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeAttr, hSpan, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* value_len *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nVal), 8);
    pBuffer^.DataAdded(8);

    AddLInt := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddReal" Id="{6a9dc70f-5325-45d1-8be5-172af842881e}">
      <Declaration><![CDATA[METHOD PUBLIC AddReal : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    fVal  : LREAL;
END_VAR
VAR
    nKeyLen     : UDINT;
    nKeyLenUsint : USINT;
    nDcTime     : LINT;
    nTaskIdx    : USINT;
    nValueType  : BYTE := 2;
    pBuffer     : POINTER TO FB_LogBuffer;
    nTotalLen   : UDINT;
    nFlags      : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value(8) *)
nTotalLen := 12 + 4 + nKeyLen + 8;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeAttr, hSpan, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* value_len *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(fVal), 8);
    pBuffer^.DataAdded(8);

    AddReal := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AddString" Id="{59a3fb41-a2f5-4bd0-ad49-dd002f212acc}">
      <Declaration><![CDATA[METHOD PUBLIC AddString : BOOL
VAR_INPUT
    hSpan : USINT;
    sKey  : STRING(30);
    sVal  : STRING(120);
END_VAR
VAR
    nKeyLen      : UDINT;
    nKeyLenUsint : USINT;
    nValLen      : UDINT;
    nValLenUsint : USINT;
    nDcTime      : LINT;
    nTaskIdx     : USINT;
    nValueType   : BYTE := 4;
    pBuffer      : POINTER TO FB_LogBuffer;
    nTotalLen    : UDINT;
    nFlags       : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nKeyLen := Tc2_Utilities.LEN2(ADR(sKey));
IF nKeyLen > 31 THEN
    nKeyLen := 31;
END_IF;
nKeyLenUsint := TO_USINT(nKeyLen);

nValLen := Tc2_Utilities.LEN2(ADR(sVal));
IF nValLen > 127 THEN
    nValLen := 127;
END_IF;
nValLenUsint := TO_USINT(nValLen);

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(12) + value_type(1) + key_len(1) + value_len(1) + reserved(1) + key + value *)
nTotalLen := 12 + 4 + nKeyLen + nValLen;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeAttr, hSpan, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nKeyLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nValueType), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    IF nKeyLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sKey), nKeyLen);
        pBuffer^.DataAdded(nKeyLen);
    END_IF;

    IF nValLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sVal), nValLen);
        pBuffer^.DataAdded(nValLen);
    END_IF;

    AddString := TRUE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Begin" Id="{832e89db-497a-4d07-b3b1-c6e95e2f7e46}">
      <Declaration><![CDATA[METHOD PUBLIC Begin : USINT
VAR_INPUT
    sName        : STRING(60);
    eKind        : E_SpanKind := E_SpanKind.eInternal;
    sTraceParent : STRING(60) := '';
END_VAR
VAR
    hSpan           : USINT;
    nTaskIndex      : USINT;
    nNameLen        : UDINT;
    nNameLenUsint   : USINT;
    nTpLen          : UDINT;
    nTpLenUsint     : USINT;
    nFlagsBegin     : BYTE;
    nTotalLen       : UDINT;
    nDcTime         : LINT;
    pBuffer         : POINTER TO FB_LogBuffer;
    eKindByte       : BYTE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Allocate next slot *)
hSpan := nNextLocalId;
IF hSpan > 254 THEN
    RETURN;  (* Guard against 0xFF reserved value *)
END_IF

(* Mark slot as in-use and record parent *)
aSlots[hSpan].bInUse := TRUE;
IF nStackDepth > 0 THEN
    aSlots[hSpan].parent_local_id := aStack[nStackDepth - 1];
ELSE
    aSlots[hSpan].parent_local_id := 16#FF;
END_IF

(* Mint local trace_id (16B) and span_id (8B) into the slot so
   CurrentTraceParent() has real IDs to format for outbound propagation.
   The Rust dispatcher honours these when flag_local_ids is set. *)
_SeedRng();
_MintTraceId(hSpan);
_MintSpanId(hSpan);

(* Push onto stack *)
IF nStackDepth < 16 THEN
    aStack[nStackDepth] := hSpan;
    nStackDepth := nStackDepth + 1;
END_IF

(* Prepare flags *)
nFlagsBegin := 0;
IF aSlots[hSpan].parent_local_id = 16#FF THEN
    nFlagsBegin := nFlagsBegin OR 1;  (* flag_is_root *)
END_IF;
IF Tc2_Utilities.LEN2(ADR(sTraceParent)) > 0 THEN
    nFlagsBegin := nFlagsBegin OR 2;  (* flag_has_external_parent *)
END_IF;
(* flag_local_ids: 24 bytes (trace_id + span_id) appended after reserved *)
nFlagsBegin := nFlagsBegin OR 8;

(* Get current time and task index *)
nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIndex := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Prepare frame sizes *)
nNameLen := Tc2_Utilities.LEN2(ADR(sName));
IF nNameLen > 127 THEN
    nNameLen := 127;
END_IF;
nNameLenUsint := TO_USINT(nNameLen);

nTpLen := 0;
nTpLenUsint := 0;
IF (nFlagsBegin AND 2) <> 0 THEN
    nTpLen := Tc2_Utilities.LEN2(ADR(sTraceParent));
    IF nTpLen > 127 THEN
        nTpLen := 127;
    END_IF;
    nTpLenUsint := TO_USINT(nTpLen);
END_IF;

(* Total frame size: header(12) + parent(1) + kind(1) + name_len(1) + reserved(1)
   + [if flag_local_ids: trace_id(16) + span_id(8)]
   + name
   + [if flag_has_external_parent: tp_len(1) + tp] *)
nTotalLen := 12 + 4 + nNameLen;
IF (nFlagsBegin AND 8) <> 0 THEN
    nTotalLen := nTotalLen + 24;
END_IF;
IF (nFlagsBegin AND 2) <> 0 THEN
    nTotalLen := nTotalLen + 1 + nTpLen;
END_IF;

(* Write frame *)
pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeBegin, hSpan, nTaskIndex, nFlagsBegin, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(aSlots[hSpan].parent_local_id), 1);
    pBuffer^.DataAdded(1);

    eKindByte := TO_BYTE(eKind);
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(eKindByte), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nNameLenUsint), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nEventTypeBegin), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    (* Local IDs section — 16 bytes trace_id + 8 bytes span_id.
       Emitted only when flag_local_ids (bit 3) is set; consumer-side
       parser knows the layout from the flag. Copied directly from the
       slot storage so CurrentTraceParent() can cite the same bytes. *)
    IF (nFlagsBegin AND 8) <> 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(aSlots[hSpan].trace_id[0]), 16);
        pBuffer^.DataAdded(16);
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(aSlots[hSpan].span_id[0]), 8);
        pBuffer^.DataAdded(8);
    END_IF;

    IF nNameLen > 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sName), nNameLen);
        pBuffer^.DataAdded(nNameLen);
    END_IF;

    IF (nFlagsBegin AND 2) <> 0 THEN
        Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nTpLenUsint), 1);
        pBuffer^.DataAdded(1);

        IF nTpLen > 0 THEN
            Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(sTraceParent), nTpLen);
            pBuffer^.DataAdded(nTpLen);
        END_IF;
    END_IF;
END_IF;

(* Increment for next allocation; wrap at 254 because 0xFF is reserved. *)
IF nNextLocalId >= 254 THEN
    nNextLocalId := 0;
ELSE
    nNextLocalId := nNextLocalId + 1;
END_IF;

Begin := hSpan;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Call" Id="{b918082d-1f06-4f72-b609-d97e60f0a088}">
      <Declaration><![CDATA[METHOD PUBLIC Call
(* No-op in Phase-1: wire events flushed on emission. *)
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="CurrentTraceParent" Id="{703b7f93-e680-4a9f-a268-bebc44b81a3d}">
      <Declaration><![CDATA[(*
:Description: Format a W3C traceparent header for the innermost open span.

Returns '' when no span is open. Format: `00-<32hex>-<16hex>-01`.
Must be called BEFORE the span's End(); the slot is recycled on End.
Used to ship trace context across task / PLC / RPC boundaries.
*)
METHOD PUBLIC CurrentTraceParent : STRING(60)
VAR
    hSpan     : USINT;
    i         : INT;
    sHex      : STRING(60);
    nNibble   : BYTE;
    achHex    : ARRAY[0..15] OF BYTE := [16#30, 16#31, 16#32, 16#33, 16#34, 16#35, 16#36, 16#37, 16#38, 16#39, 16#61, 16#62, 16#63, 16#64, 16#65, 16#66];
    achOut    : ARRAY[0..55] OF BYTE;  (* "00-" + 32 + "-" + 16 + "-01" = 55 chars *)
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF nStackDepth = 0 THEN
    CurrentTraceParent := '';
    RETURN;
END_IF;

hSpan := aStack[nStackDepth - 1];
IF NOT aSlots[hSpan].bInUse THEN
    CurrentTraceParent := '';
    RETURN;
END_IF;

(* Layout: "00-" (3) + trace_id_hex (32) + "-" (1) + span_id_hex (16) + "-01" (3) = 55 chars *)
achOut[0] := 16#30;  (* '0' *)
achOut[1] := 16#30;  (* '0' *)
achOut[2] := 16#2D;  (* '-' *)

FOR i := 0 TO 15 DO
    nNibble := SHR(aSlots[hSpan].trace_id[i], 4) AND 16#0F;
    achOut[3 + i * 2]     := achHex[nNibble];
    nNibble := aSlots[hSpan].trace_id[i] AND 16#0F;
    achOut[3 + i * 2 + 1] := achHex[nNibble];
END_FOR

achOut[35] := 16#2D;  (* '-' *)

FOR i := 0 TO 7 DO
    nNibble := SHR(aSlots[hSpan].span_id[i], 4) AND 16#0F;
    achOut[36 + i * 2]     := achHex[nNibble];
    nNibble := aSlots[hSpan].span_id[i] AND 16#0F;
    achOut[36 + i * 2 + 1] := achHex[nNibble];
END_FOR

achOut[52] := 16#2D;  (* '-' *)
achOut[53] := 16#30;  (* '0' *)
achOut[54] := 16#31;  (* '1' *)

(* Copy 55 bytes + null terminator into the STRING(60) output. *)
Tc2_System.MEMCPY(ADR(sHex), ADR(achOut[0]), 55);
sHex[55] := 0;
CurrentTraceParent := sHex;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="End" Id="{82740a99-7e02-4458-aaa7-fef1872d30eb}">
      <Declaration><![CDATA[METHOD PUBLIC End : BOOL
VAR_INPUT
    hSpan : USINT;
END_VAR
VAR
    nTaskIdx   : USINT;
    nDcTime    : LINT;
    nStatus    : BYTE := 1;
    nMsgLen    : USINT := 0;
    pBuffer    : POINTER TO FB_LogBuffer;
    nTotalLen  : UDINT;
    nFlags     : BYTE := 0;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

nDcTime := TO_LINT(Tc2_EtherCAT.F_GetActualDcTime64());
IF nDcTime = 0 THEN
    nDcTime := _GetTaskDcTime();
END_IF;
nTaskIdx := TO_USINT(Tc2_Utilities.GETCURTASKINDEXEX());

(* Frame: header(12) + status(1) + msg_len(1) + reserved(2) + msg *)
nTotalLen := 12 + 4 + nMsgLen;

pBuffer := PRG_TaskLog.TaskLogger.WriteBuffer;
IF pBuffer <> 0 AND_THEN pBuffer^.BufferFree >= nTotalLen THEN
    (* Header *)
    _WriteFrameHeader(pBuffer, nEventTypeEnd, hSpan, nTaskIdx, nFlags, nDcTime);

    (* Payload *)
    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nStatus), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nMsgLen), 1);
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nStatus), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    Tc2_System.MEMCPY(pBuffer^.BufferPtr, ADR(nStatus), 1);  (* reserved *)
    pBuffer^.DataAdded(1);

    End := TRUE;
END_IF;

(* Pop from stack if on top *)
IF nStackDepth > 0 AND aStack[nStackDepth - 1] = hSpan THEN
    nStackDepth := nStackDepth - 1;
END_IF;

(* Free the slot *)
aSlots[hSpan].bInUse := FALSE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetError" Id="{1323314a-5f82-499e-a923-f4a110bbfa07}">
      <Declaration><![CDATA[METHOD PUBLIC SetError : BOOL
VAR_INPUT
    hSpan : USINT;
    sMsg  : STRING(120) := '';
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT aSlots[hSpan].bInUse THEN
    RETURN;
END_IF;

(* Phase-1: Store error state. FB_Span will pass error status to End(). *)
SetError := TRUE;
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>