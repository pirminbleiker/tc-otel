<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4022.10">
  <POU Name="FB_PushDiag" Id="{7a8b9c0d-1e2f-3a4b-5c6d-7e8f9a0b1c2d}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_PushDiag
VAR_INPUT
    sTcOtelNetId        : T_AmsNetId;    // tc-otel's network ID
    nTcOtelPort         : UINT := 16150; // tc-otel's ADS port
    nSnapshotIntervalMs : UDINT := 1000; // Snapshot send interval in milliseconds
    bEnabled            : BOOL := TRUE;  // Enable/disable the push diagnostics
END_VAR

VAR
    // Access to TwinCAT task info (external)
    pSystemInfo         : POINTER TO ST_TcSysInfoVarList;

    // Timer for snapshot interval
    tSnapshotTimer      : TON;
    bSnapshotSentThisInterval : BOOL;

    // Previous-cycle edge detection arrays
    abPrevCycleExceeded : ARRAY [0..63] OF BOOL;
    abPrevRTViolation   : ARRAY [0..63] OF BOOL;

    // Snapshot buffer (max 64 tasks × 72 bytes + 16 byte header = 4624 bytes)
    abySnapshotBuffer   : ARRAY [0..4623] OF BYTE;

    // Edge event buffer (44 bytes)
    abyEdgeBuffer       : ARRAY [0..43] OF BYTE;

    // Working variables
    nTaskCount          : DINT;
    nTaskIndex          : DINT;
    nBufferOffset       : DINT;
    nNameLen            : DINT;
    fbAdsWrite          : Tc2_System.ADSWRITE;
    u64Timestamp        : ULINT;
    nHeaderSize         : DINT := 16;
    nRecordSize         : DINT := 72;
    nEdgeSize           : DINT := 44;
END_VAR

VAR_TEMP
    stHeader            : ST_PushDiagHeader;
    stTaskRecord        : ST_PushDiagTaskRecord;
    stEdge              : ST_PushDiagEdge;
    pTaskInfo           : POINTER TO ST_TaskInfo;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* FB_PushDiag - Push diagnostics to tc-otel *)
IF NOT bEnabled THEN
    RETURN;
END_IF

(* Initialize system info access on first cycle *)
IF pSystemInfo = 0 THEN
    pSystemInfo := ADR(TwinCAT_SystemInfoVarList.PlcAppSystemInfo);
END_IF

(* Guard against invalid pointer *)
IF pSystemInfo = 0 THEN
    RETURN;
END_IF

(* Get timestamp *)
u64Timestamp := Tc2_System.F_GetCurTaskCycleCount() * 1000000; (* Approximate nanosecond conversion *)

(* Get task count *)
nTaskCount := pSystemInfo^.TaskCount;
IF nTaskCount < 0 OR nTaskCount > 64 THEN
    nTaskCount := 0;
END_IF

(* Process each task for edge events *)
FOR nTaskIndex := 0 TO nTaskCount - 1 DO
    pTaskInfo := ADR(pSystemInfo^.TaskInfo[nTaskIndex]);

    (* Detect CycleTimeExceeded edge (0 -> 1) *)
    IF pTaskInfo^.CycleTimeExceeded AND NOT abPrevCycleExceeded[nTaskIndex] THEN
        abPrevCycleExceeded[nTaskIndex] := TRUE;

        (* Build edge event for cycle-exceed *)
        stEdge.version := 1;
        stEdge.event_type := 1;
        stEdge.reserved := 0;
        stEdge.ads_port := pTaskInfo^.AdsPort;
        stEdge.cycle_count := pTaskInfo^.CycleCount;
        stEdge.last_exec_time_us := pTaskInfo^.LastExecTime;
        stEdge.reserved2 := 0;

        (* Copy task name (null-padded to 20 bytes) *)
        Tc2_System.MEMSET(ADR(stEdge.task_name), 0, 20);
        nNameLen := Tc2_System.STRLEN(pTaskInfo^.TaskName);
        IF nNameLen > 19 THEN
            nNameLen := 19;
        END_IF
        IF nNameLen > 0 THEN
            Tc2_System.MEMCPY(ADR(stEdge.task_name), ADR(pTaskInfo^.TaskName), nNameLen);
        END_IF

        (* Copy struct to buffer and send *)
        Tc2_System.MEMCPY(ADR(abyEdgeBuffer), ADR(stEdge), nEdgeSize);
        fbAdsWrite(
            NETID := sTcOtelNetId,
            PORT := nTcOtelPort,
            IDXGRP := 16#4D424301,
            IDXOFFS := 1,
            LEN := nEdgeSize,
            SRCADDR := ADR(abyEdgeBuffer),
            BUSY => ,
            ERR => ,
            ERRID =>
        );
    ELSIF NOT pTaskInfo^.CycleTimeExceeded AND abPrevCycleExceeded[nTaskIndex] THEN
        abPrevCycleExceeded[nTaskIndex] := FALSE;
    END_IF

    (* Detect RTViolation edge (0 -> 1) *)
    IF pTaskInfo^.RTViolation AND NOT abPrevRTViolation[nTaskIndex] THEN
        abPrevRTViolation[nTaskIndex] := TRUE;

        (* Build edge event for RT violation *)
        stEdge.version := 1;
        stEdge.event_type := 2;
        stEdge.reserved := 0;
        stEdge.ads_port := pTaskInfo^.AdsPort;
        stEdge.cycle_count := pTaskInfo^.CycleCount;
        stEdge.last_exec_time_us := pTaskInfo^.LastExecTime;
        stEdge.reserved2 := 0;

        (* Copy task name *)
        Tc2_System.MEMSET(ADR(stEdge.task_name), 0, 20);
        nNameLen := Tc2_System.STRLEN(pTaskInfo^.TaskName);
        IF nNameLen > 19 THEN
            nNameLen := 19;
        END_IF
        IF nNameLen > 0 THEN
            Tc2_System.MEMCPY(ADR(stEdge.task_name), ADR(pTaskInfo^.TaskName), nNameLen);
        END_IF

        (* Copy struct to buffer and send *)
        Tc2_System.MEMCPY(ADR(abyEdgeBuffer), ADR(stEdge), nEdgeSize);
        fbAdsWrite(
            NETID := sTcOtelNetId,
            PORT := nTcOtelPort,
            IDXGRP := 16#4D424301,
            IDXOFFS := 2,
            LEN := nEdgeSize,
            SRCADDR := ADR(abyEdgeBuffer),
            BUSY => ,
            ERR => ,
            ERRID =>
        );
    ELSIF NOT pTaskInfo^.RTViolation AND abPrevRTViolation[nTaskIndex] THEN
        abPrevRTViolation[nTaskIndex] := FALSE;
    END_IF
END_FOR

(* Check snapshot timer *)
tSnapshotTimer(IN := TRUE, PT := nSnapshotIntervalMs);

IF tSnapshotTimer.Q AND NOT bSnapshotSentThisInterval THEN
    bSnapshotSentThisInterval := TRUE;

    (* Build snapshot header *)
    stHeader.version := 1;
    stHeader.event_type := 0;
    stHeader.num_tasks := DINT_TO_UINT(nTaskCount);
    stHeader.plc_timestamp_ns := u64Timestamp;
    stHeader.reserved := 0;

    (* Copy header to buffer *)
    Tc2_System.MEMCPY(ADR(abySnapshotBuffer), ADR(stHeader), nHeaderSize);
    nBufferOffset := nHeaderSize;

    (* Build and append task records *)
    FOR nTaskIndex := 0 TO nTaskCount - 1 DO
        pTaskInfo := ADR(pSystemInfo^.TaskInfo[nTaskIndex]);

        stTaskRecord.task_obj_id := pTaskInfo^.ObjId;
        stTaskRecord.ads_port := pTaskInfo^.AdsPort;
        stTaskRecord.priority := pTaskInfo^.Priority;
        stTaskRecord.cycle_time_us := pTaskInfo^.CycleTime;
        stTaskRecord.last_exec_time_us := pTaskInfo^.LastExecTime;
        stTaskRecord.reserved := 0;
        stTaskRecord.cycle_count := pTaskInfo^.CycleCount;
        stTaskRecord.cycle_exceed_count := pTaskInfo^.CycleExceededCount;
        stTaskRecord.rt_violation_count := pTaskInfo^.RTViolationCount;

        (* Flags: bit0=CycleTimeExceeded, bit1=RTViolation, bit2=FirstCycle *)
        stTaskRecord.flags := 0;
        IF pTaskInfo^.CycleTimeExceeded THEN
            stTaskRecord.flags := stTaskRecord.flags OR 16#01;
        END_IF
        IF pTaskInfo^.RTViolation THEN
            stTaskRecord.flags := stTaskRecord.flags OR 16#02;
        END_IF
        IF pTaskInfo^.FirstCycle THEN
            stTaskRecord.flags := stTaskRecord.flags OR 16#04;
        END_IF

        (* Copy task name *)
        Tc2_System.MEMSET(ADR(stTaskRecord.task_name), 0, 20);
        nNameLen := Tc2_System.STRLEN(pTaskInfo^.TaskName);
        IF nNameLen > 19 THEN
            nNameLen := 19;
        END_IF
        IF nNameLen > 0 THEN
            Tc2_System.MEMCPY(ADR(stTaskRecord.task_name), ADR(pTaskInfo^.TaskName), nNameLen);
        END_IF

        (* Copy record to snapshot buffer *)
        Tc2_System.MEMCPY(
            ADR(abySnapshotBuffer) + nBufferOffset,
            ADR(stTaskRecord),
            nRecordSize
        );
        nBufferOffset := nBufferOffset + nRecordSize;
    END_FOR

    (* Send snapshot via ADSWRITE *)
    fbAdsWrite(
        NETID := sTcOtelNetId,
        PORT := nTcOtelPort,
        IDXGRP := 16#4D424301,
        IDXOFFS := 0,
        LEN := nBufferOffset,
        SRCADDR := ADR(abySnapshotBuffer),
        BUSY => ,
        ERR => ,
        ERRID =>
    );
ELSIF NOT tSnapshotTimer.Q THEN
    (* Timer expired and reset for next interval *)
    bSnapshotSentThisInterval := FALSE;
END_IF
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
