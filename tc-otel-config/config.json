        "ams_port": 852,
        "ams_router_host": "tc31-xar-base",
        "poll": {
          "interval_ms": 100
        },
        "notification": null
      },
      {
        "symbol": "PRG_TestTracePropagation.nSeq",
        "metric_name": "plc.test.propagation.seq",
        "description": "Notification: workpiece sequence counter (fires on change)",
        "unit": "1",
        "kind": "gauge",
        "is_monotonic": false,
        "source": "notification",
        "ams_net_id": "175.57.15.0.1.1",
        "ams_port": 852,
        "ams_router_host": "tc31-xar-base",
        "poll": null,
        "notification": {
          "min_period_ms": 1,
          "max_period_ms": 1,
          "max_delay_ms": 1,
          "transmission_mode": "cyclic"
        }
      }
    ],
    "cycle_time_enabled": true,
    "cycle_time_window": 1000,
    "export_batch_size": 100,
    "export_enabled": true,
    "export_endpoint": null,
    "export_flush_interval_ms": 1000
  },
  "outputs": [],
  "receiver": {
    "ads_port": 16150,
    "ams_net_id": "10.10.10.10.1.1",
    "ams_tcp_port": 48898,
