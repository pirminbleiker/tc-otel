{
  "logging": {
    "log_level": "info",
    "format": "text",
    "output_path": null
  },
  "receiver": {
    "host": "0.0.0.0",
    "http_port": 4318,
    "grpc_port": 4317,
    "max_body_size": 4194304,
    "request_timeout_secs": 30,
    "ams_net_id": "10.10.10.10.1.1",
    "ams_tcp_port": 48898,
    "ads_port": 16150,
    "max_connections": 100,
    "idle_timeout_secs": 300,
    "max_connections_per_ip": 10,
    "rate_limit_per_sec_per_ip": 10,
    "keepalive_interval_secs": 60,
    "send_buffer_size": 1048576,
    "transport": {
      "type": "mqtt",
      "broker": "mosquitto:1883",
      "topic_prefix": "AdsOverMqtt",
      "client_id": "tc-otel-compose"
    }
  },
  "export": {
    "endpoint": "http://otel-collector:4318/v1/logs",
    "batch_size": 100,
    "flush_interval_ms": 5000,
    "timeout_secs": 10,
    "max_retries": 3
  },
  "outputs": [],
  "service": {
    "name": "tc-otel",
    "display_name": "tc-otel - TwinCAT OpenTelemetry Service (MQTT)",
    "worker_threads": null,
    "channel_capacity": 50000,
    "shutdown_timeout_secs": 30
  },
  "web": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 8080,
    "max_subscriptions": 500
  },
  "metrics": {
    "cycle_time_enabled": true,
    "cycle_time_window": 1000,
    "custom_metrics": [],
    "export_enabled": true,
    "export_batch_size": 100,
    "export_flush_interval_ms": 1000
  },
  "diagnostics": {
    "enabled": true,
    "targets": [
      {
        "ams_net_id": "172.28.41.37.1.1",
        "poll_interval_ms": 200,
        "exceed_counter": true,
        "rt_usage": true,
        "task_ports": [340, 350, 351],
        "rt_port": 200,
        "task_names": {
          "340": "IO Idle",
          "350": "PlcTask",
          "351": "PlcTask1"
        }
      }
    ]
  }
}