{
  "diagnostics": {
    "enabled": true,
    "targets": [
      {
        "ams_net_id": "172.28.41.37.1.1",
        "exceed_counter": true,
        "poll_interval_ms": 200,
        "rt_port": 200,
        "rt_usage": true,
        "task_names": {
          "340": "IO Idle",
          "350": "PlcTask",
          "351": "PlcTask1"
        },
        "task_ports": [
          340,
          350,
          351
        ]
      }
    ]
