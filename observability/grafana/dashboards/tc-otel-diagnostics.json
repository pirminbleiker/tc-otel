      "id": 4,
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "rate(tc_rt_exceed_counter_total[1m]) * 60",
          "legendFormat": "{{ams_net_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
