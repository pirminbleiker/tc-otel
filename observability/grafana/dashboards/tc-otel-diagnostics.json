      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 18,
        "y": 65
      },
      "id": 32,
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "tc_task_window_ms",
          "legendFormat": "{{task_name}}",
          "refId": "A"
        }
      ]
