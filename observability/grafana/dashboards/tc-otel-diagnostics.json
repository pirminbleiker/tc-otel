    {
      "type": "stat",
      "title": "Cycle Exceeds (time range total)",
      "description": "Total number of individual exceeded cycles in the current time range.",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 38
      },
      "id": 22,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "sum_over_time(tc_task_cycle_exceed_window[$__range])",
          "legendFormat": "{{task_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "RT Violations (time range total)",
      "description": "Total RT-violation count over the dashboard's time range.",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 38
      },
      "id": 23,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "sum_over_time(tc_task_rt_violation_window[$__range])",
          "legendFormat": "{{task_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Exceeds/min (trailing 1-minute total, rolling)",
      "description": "At each time point: total number of exceeding cycles in the preceding 60 seconds. Fixed lookback window independent of display step \u2014 no overlap double-counting, no step-size sensitivity. For the absolute total use the stat panel above.",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 43
      },
      "id": 20,
      "interval": "5s",
      "maxDataPoints": 500,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 20,
            "pointSize": 3,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "expr": "sum_over_time(tc_task_cycle_exceed_window[1m])",
          "legendFormat": "{{task_name}} exceeds/min",
          "refId": "A"
        },
        {
          "expr": "sum_over_time(tc_task_rt_violation_window[1m])",
          "legendFormat": "{{task_name}} rtv/min",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
