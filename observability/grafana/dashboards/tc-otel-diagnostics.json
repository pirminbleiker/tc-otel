    {
      "type": "logs",
      "title": "Task logs in range",
      "description": "All PLC logs in the dashboard time range. For deeper analysis open Grafana Explore on the VictoriaLogs data source and query by task.cycle, severity, etc.\n\nLog rows with `trace_id=...` / `span_id=...` are turned into clickable links by the VictoriaLogs derivedFields config and jump to the VictoriaTraces datasource.",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "victoria-logs"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 52
      },
      "id": 40,
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "*",
          "queryType": "instant"
        }
      ]
    },
    {
      "type": "row",
      "title": "Sampler Health (push \u2014 meta)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 64
      },
      "id": 103,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Samples per Window",
      "description": "Number of samples the PLC shipped in each batch. Stays well below 1024 in healthy operation.",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 65
      },
      "id": 30,
      "interval": "1s",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "max": 1024,
