    {
      "type": "stat",
      "title": "Ring Buffer Overflow",
      "description": "1 = the 1024-sample ring filled before the window flushed. Older samples were overwritten; tune window_ms down or divider up.",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 12,
        "y": 65
      },
      "id": 31,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
